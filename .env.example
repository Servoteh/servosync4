# Kopiraj u .env: cp .env.example .env
# Postgres iz docker-compose.yml mora da radi: docker compose up -d db

DATABASE_URL="postgresql://servosync:servosync_dev@localhost:5435/servosync?schema=public"
PORT=3000

# Optional: serve the built frontend (Next static export `out/`) from THIS API on the
# same origin — LAN/offline access without Cloudflare or CORS (front na http://<host>:3000,
# API na .../api). Point at the dir that holds index.html/login.html. Prazno = samo API
# (dev/default). Na serveru je to montirani volume, npr. /app/frontend-static
# (v. docs/infra/INFRASTRUKTURA.md → „Front na :3000").
FRONTEND_STATIC_DIR=

# --- BigBit / QBigTehn (MSSQL) source for on-demand sync ---
# Read-only login (bridge_reader already exists in QBigTehn). Reachable over the
# company WireGuard VPN. Use the FQDN (or IP 192.168.64.25) — the bare NetBIOS
# name "Vasa-SQL" does not resolve on macOS.
BIGBIT_DB_HOST=Vasa-SQL.servoteh.local
BIGBIT_DB_PORT=5765
BIGBIT_DB_NAME=QBigTehn
BIGBIT_DB_USER=bridge_reader
BIGBIT_DB_PASSWORD=
BIGBIT_DB_ENCRYPT=false
BIGBIT_DB_TRUST_SERVER_CERT=true
BIGBIT_DB_REQUEST_TIMEOUT_MS=30000
BIGBIT_DB_POOL_MAX=5

# --- Auth (JWT) ---
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
# SSO sa ServoSync 1.0/1.5 shell-a (iframe modul „Tehnologija"): JWT_SECRET
# sy15 GoTrue stacka (na serveru: ~/servosync15/.env). POST /api/auth/sso
# verifikuje 1.0 access token ovim secretom i po email-u (users.email) izda
# naš token. Prazno = SSO isključen (endpoint vraća 401).
SY15_JWT_SECRET=

# --- Authz (RBAC guard rollout, AUTHZ_UNIFIED.md §6.1/§8) ---
# false (default) = SHADOW MODE: guard evaluates + logs would-be 403s, but allows.
# true = enforce (403 on missing permission). Rollback = flip back + restart.
AUTHZ_ENFORCE=false
