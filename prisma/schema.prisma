// ServoSync target schema (PostgreSQL).
//
// Naming conventions (see docs/schema-rename-map.md for the full Serbian->English map):
//   - Prisma models  : PascalCase, singular (Customer, Project, WorkOrder, ...)
//   - Prisma fields  : camelCase                  (firstName, customerId, ...)
//   - DB tables      : snake_case, plural        (customers, projects, work_orders, ...)
//   - DB columns     : snake_case                (first_name, customer_id, ...)
//   - Constraints    : pk_<table>, fk_<table>_<ref>, uq_<table>_<cols>, idx_<table>_<cols>
//
// Legacy Serbian names are not preserved at the database level. The mapping doc
// (docs/schema-rename-map.md) is the single source of truth for "old -> new".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE / CONFIG
// ============================================================================

/// Per-user UI defaults (was: BBDefUser).
model DefaultUser {
  username            String              @id(map: "pk_default_users") @map("username") @db.VarChar(20)
  defaultYear         Int?                @default(dbgenerated("(EXTRACT(year FROM CURRENT_DATE))::integer")) @map("default_year")
  defaultOrgUnitId    Int?                @default(0) @map("default_org_unit_id")
  defaultDepartmentId Int?                @default(0) @map("default_department_id")
  unlockYear          Boolean?            @default(false) @map("unlock_year")
  unlockOrgUnit       Boolean?            @default(false) @map("unlock_org_unit")
  unlockDepartment    Boolean?            @default(false) @map("unlock_department")
  level               Int?                @default(0) @map("level") @db.SmallInt
  maxLevel            Int?                @default(0) @map("max_level") @db.SmallInt
  department          Department?         @relation(fields: [defaultDepartmentId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_default_users_departments")
  organizationalUnit  OrganizationalUnit? @relation(fields: [defaultOrgUnitId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_default_users_organizational_units")

  @@map("default_users")
}

/// Was: BBOdeljenja
model Department {
  id           Int           @id(map: "pk_departments") @default(autoincrement()) @map("id")
  code         String        @map("code") @db.VarChar(10)
  description  String        @map("description") @db.VarChar(50)
  defaultUsers DefaultUser[]

  @@map("departments")
}

/// Was: BBOrgJedinice
model OrganizationalUnit {
  id           Int           @id(map: "pk_organizational_units") @default(autoincrement()) @map("id")
  code         String        @map("code") @db.VarChar(10)
  description  String        @map("description") @db.VarChar(50)
  defaultUsers DefaultUser[]

  @@map("organizational_units")
}

/// Was: BBPravaPristupa
model AccessRight {
  id           Int     @id(map: "pk_access_rights") @default(autoincrement()) @map("id")
  username     String  @map("username") @db.VarChar(20)
  formName     String  @map("form_name") @db.VarChar(50)
  controlName  String  @map("control_name") @db.VarChar(50)
  visible      Boolean @default(true) @map("visible")
  locked       Boolean @default(false) @map("locked")
  enabled      Boolean @default(true) @map("enabled")
  value        String? @map("value") @db.VarChar(250)
  recordSource String? @map("record_source")
  filter       String? @map("filter") @db.VarChar(250)

  @@map("access_rights")
}

/// Was: CFG_Global (per-company parameters)
model GlobalConfig {
  companyId   Int     @default(0) @map("company_id")
  parameter   String  @map("parameter") @db.VarChar(120)
  value       String? @map("value")
  type        String? @map("type") @db.VarChar(20)
  description String? @map("description") @db.VarChar(100)

  @@id([companyId, parameter], map: "pk_global_config")
  @@map("global_config")
}

/// Was: CFG_Sys (system-wide parameters)
model SystemConfig {
  parameter   String    @id(map: "pk_system_config") @map("parameter") @db.VarChar(120)
  value       String?   @map("value") @db.VarChar(50)
  type        String?   @map("type") @db.VarChar(20)
  description String?   @map("description") @db.VarChar(255)
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("system_config")
}

// ============================================================================
// PRICING & TAX REFERENCE
// ============================================================================

/// Was: Cenovnik (price entries by article + document type)
model PriceListEntry {
  id                Int      @id(map: "pk_price_list_entries") @default(autoincrement()) @map("id")
  itemId            Int      @default(0) @map("item_id")
  documentTypeId    String   @map("document_type_code") @db.VarChar(5)
  price             Float?   @default(0) @map("price")
  taxRateCode       String   @map("tax_rate_code") @db.VarChar(5)
  priceWithoutVat   Decimal? @default(0) @map("price_without_vat") @db.Decimal(19, 4)
  fee               Float?   @default(0) @map("fee")
  print             Boolean? @default(true) @map("print")
  priceWithVat      Decimal? @default(0) @map("price_with_vat") @db.Decimal(19, 4)
  checkPriceWithVat Boolean? @default(false) @map("check_price_with_vat")
  isLocked          Boolean? @default(false) @map("is_locked")
  item              Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_price_list_entries_items")
  taxRate           TaxRate  @relation(fields: [taxRateCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_price_list_entries_tax_rates")

  @@map("price_list_entries")
}

/// Was: R_Tarife
model TaxRate {
  id               Int              @id(map: "pk_tax_rates") @default(autoincrement()) @map("id")
  code             String           @unique(map: "uq_tax_rates_code") @map("code") @db.VarChar(5)
  baseRate         Float?           @default(0) @map("base_rate")
  railwayRate      Float?           @default(0) @map("railway_rate")
  cityRate         Float?           @default(0) @map("city_rate")
  warRate          Float?           @default(0) @map("war_rate")
  specialRate      Float?           @default(0) @map("special_rate")
  description      String?          @map("description")
  validFrom        DateTime?        @map("valid_from") @db.Timestamp(6)
  validTo          DateTime?        @map("valid_to") @db.Timestamp(6)
  vatGroup         String?          @default("VISA") @map("vat_group") @db.VarChar(10)
  priceListEntries PriceListEntry[]

  @@map("tax_rates")
}

// ============================================================================
// SYSTEM NOTIFICATIONS
// ============================================================================

/// Was: Info (message/notification audit)
model Notification {
  id         Int       @id(map: "pk_notifications") @default(0) @map("id")
  sentAt     DateTime? @map("sent_at") @db.Timestamp(6)
  sentBy     String?   @map("sent_by") @db.VarChar(250)
  received   Boolean?  @default(false) @map("received")
  receivedAt DateTime? @map("received_at") @db.Timestamp(6)
  receivedBy String?   @map("received_by") @db.VarChar(250)

  @@map("notifications")
}

// ============================================================================
// CUSTOMERS
// ============================================================================

/// Was: Komitenti
model Customer {
  id                         Int          @id(map: "pk_customers") @default(autoincrement()) @map("id")
  name                       String       @map("name") @db.VarChar(50)
  branch                     String?      @map("branch") @db.VarChar(50)
  city                       String?      @map("city") @db.VarChar(30)
  address                    String?      @map("address") @db.VarChar(50)
  postalCode                 String?      @map("postal_code") @db.VarChar(20)
  bankAccount1               String?      @map("bank_account_1") @db.VarChar(30)
  bankAccount2               String?      @map("bank_account_2") @db.VarChar(30)
  bankAccount3               String?      @map("bank_account_3") @db.VarChar(30)
  phone                      String?      @map("phone") @db.VarChar(20)
  fax                        String?      @map("fax") @db.VarChar(20)
  contact                    String?      @map("contact") @db.VarChar(50)
  note                       String?      @map("note")
  country                    String?      @map("country") @db.VarChar(30)
  region                     Int?         @default(0) @map("region")
  codeTypeCode               String?      @default("KUPDOB") @map("code_type_code") @db.VarChar(10)
  email                      String?      @map("email") @db.VarChar(50)
  mobile                     String?      @map("mobile") @db.VarChar(20)
  birthDate                  DateTime?    @map("birth_date") @db.Timestamp(6)
  webAddress                 String?      @map("web_address") @db.VarChar(50)
  salespersonId              Int?         @default(0) @map("salesperson_id")
  customerDiscount           Float?       @default(0) @map("customer_discount")
  buyerProtectionCode        String?      @map("buyer_protection_code") @db.VarChar(50)
  taxId                      String       @map("tax_id") @db.VarChar(20)
  vatStatus                  Int?         @default(0) @map("vat_status")
  externalCode               String?      @map("external_code") @db.VarChar(10)
  paymentTermDays            Int?         @default(0) @map("payment_term_days") @db.SmallInt
  routeId                    Int?         @default(0) @map("route_id")
  driverId                   Int?         @default(0) @map("driver_id")
  paymentAccountId           Int?         @default(0) @map("payment_account_id")
  invoicePerDeliveryAddress  Boolean?     @default(true) @map("invoice_per_delivery_address")
  priceListCode              String?      @map("price_list_code") @db.VarChar(5)
  createdAt                  DateTime?    @map("created_at") @db.Timestamp(6)
  updatedAt                  DateTime?    @map("updated_at") @db.Timestamp(6)
  createdBy                  String?      @map("created_by") @db.VarChar(20)
  updatedBy                  String?      @map("updated_by") @db.VarChar(20)
  commissionPercent          Float?       @default(0) @map("commission_percent")
  fictitiousDiscount         Float?       @default(0) @map("fictitious_discount")
  paymentMethod              String?      @map("payment_method") @db.VarChar(50)
  signature                  String?      @map("signature") @db.VarChar(50)
  shortName                  String?      @map("short_name") @db.VarChar(30)
  recordCreatedAt            DateTime?    @default(now()) @map("record_created_at") @db.Timestamp(6)
  checkDebt                  Boolean?     @default(false) @map("check_debt")
  creditLimit                Decimal?     @default(0) @map("credit_limit") @db.Decimal(19, 4)
  skipTaxIdValidation        Boolean?     @default(false) @map("skip_tax_id_validation")
  pantheonId                 String?      @map("pantheon_id") @db.VarChar(30)
  newsletter                 Boolean?     @default(false) @map("newsletter")
  mailToDifferentAddress     Boolean?     @default(false) @map("mail_to_different_address")
  gln                        String?      @map("gln") @db.VarChar(30)
  manualMarkupPercent        Decimal?     @default(0) @map("manual_markup_percent") @db.Decimal(19, 4)
  balanceNote                String?      @map("balance_note")
  hideInOverview             Boolean?     @default(false) @map("hide_in_overview")
  publicSectorId             String?      @map("public_sector_id") @db.VarChar(10)
  registrationNumber         String?      @map("registration_number") @db.VarChar(20)
  einvoiceXmlPerItemDiscount Boolean?     @default(false) @map("einvoice_xml_per_item_discount")
  centralInvoiceRegistry     Boolean?     @default(false) @map("central_invoice_registry")
  salesperson                Salesperson? @relation(fields: [salespersonId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_customers_salespeople")
  driver                     Customer?    @relation("CustomerDriver", fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_customers_driver")
  customersWithThisDriver    Customer[]   @relation("CustomerDriver")
  codeType                   CodeType?    @relation(fields: [codeTypeCode], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_customers_code_types")

  @@map("customers")
}

// ============================================================================
// DRAWINGS (was PDM*)
// ============================================================================

/// Was: KomponentePDMCrteza
model DrawingComponent {
  id               Int     @id(map: "pk_drawing_components") @default(autoincrement()) @map("id")
  parentDrawingId  Int     @map("parent_drawing_id")
  childDrawingId   Int     @map("child_drawing_id")
  requiredQuantity Int     @default(1) @map("required_quantity")
  childDrawing     Drawing @relation("DrawingComponentChild", fields: [childDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_components_child")
  parentDrawing    Drawing @relation("DrawingComponentParent", fields: [parentDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_components_parent")

  @@map("drawing_components")
}

/// Was: PDMCrtezi (central drawing master)
model Drawing {
  id                 Int                 @id(map: "pk_drawings") @default(autoincrement()) @map("id")
  externalId         String              @map("external_id") @db.VarChar(20)
  transactionDate    DateTime?           @map("transaction_date") @db.Timestamp(6)
  designDate         DateTime?           @map("design_date") @db.Timestamp(6)
  designedBy         String?             @map("designed_by") @db.VarChar(50)
  approvedDate       DateTime?           @map("approved_date") @db.Timestamp(6)
  approvedBy         String?             @map("approved_by") @db.VarChar(50)
  drawingNumber      String              @map("drawing_number") @db.VarChar(20)
  revision           String              @default("A") @map("revision") @db.VarChar(3)
  quantity           Int                 @default(1) @map("quantity")
  catalogNumber      String              @map("catalog_number") @db.VarChar(50)
  name               String              @map("name") @db.VarChar(255)
  material           String?             @map("material") @db.VarChar(255)
  workOrderRef       String?             @map("work_order_ref") @db.VarChar(20)
  dimensions         String?             @map("dimensions") @db.VarChar(255)
  marking            String              @map("marking") @db.VarChar(20)
  weight             Float?              @map("weight")
  fileName           String?             @map("file_name") @db.VarChar(500)
  pdmStatus          String              @map("pdm_status") @db.VarChar(20)
  comment            String?             @map("comment") @db.VarChar(255)
  whereUsed          String?             @map("where_used") @db.VarChar(255)
  projectName        String?             @map("project_name") @db.VarChar(255)
  createdAt          DateTime?           @map("created_at") @db.Timestamp(6)
  signature          String?             @map("signature") @db.VarChar(50)
  statusId           Int                 @default(0) @map("status_id")
  isProcurement      Boolean             @default(false) @map("is_procurement")
  status             DrawingStatus       @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawings_drawing_statuses")
  childComponents    DrawingComponent[]  @relation("DrawingComponentChild")
  parentComponents   DrawingComponent[]  @relation("DrawingComponentParent")
  handoverDrafts     HandoverDraft[]
  handoverDraftItems HandoverDraftItem[]
  drawingPlans       DrawingPlan[]
  drawingPlanItems   DrawingPlanItem[]
  drawingHandovers   DrawingHandover[]
  assembliesAsChild  DrawingAssembly[]   @relation("DrawingAssemblyChild")
  assembliesAsParent DrawingAssembly[]   @relation("DrawingAssemblyParent")

  @@unique([drawingNumber, revision], map: "uq_drawings_drawing_number_revision")
  @@map("drawings")
}

/// Was: PDMXMLImportLog
model DrawingImportLog {
  id            Int      @id(map: "pk_drawing_import_log") @default(autoincrement()) @map("id")
  fileName      String   @map("file_name") @db.VarChar(255)
  filePath      String   @map("file_path") @db.VarChar(1024)
  importedAt    DateTime @default(now()) @map("imported_at") @db.Timestamp(6)
  success       Boolean  @map("success")
  statusMessage String?  @map("status_message") @db.VarChar(1000)
  isCritical    Boolean  @default(false) @map("is_critical")

  @@map("drawing_import_log")
}

/// Was: PDM_PDFCrtezi
model DrawingPdf {
  drawingNumber String   @map("drawing_number") @db.VarChar(100)
  revision      String   @map("revision") @db.VarChar(10)
  fileName      String?  @map("file_name") @db.VarChar(255)
  uploadedAt    DateTime @default(now()) @map("uploaded_at") @db.Timestamp(6)
  sizeKb        Int?     @map("size_kb")
  uploadedBy    String?  @default(dbgenerated("(SESSION_USER)::text")) @map("uploaded_by") @db.VarChar(50)
  pdfBinary     Bytes?   @map("pdf_binary")

  @@id([drawingNumber, revision], map: "pk_drawing_pdfs")
  @@map("drawing_pdfs")
}

/// Was: PDM_Planiranje
model DrawingPlan {
  id                Int               @id(map: "pk_drawing_plans") @default(autoincrement()) @map("id")
  projectId         Int               @map("project_id")
  assemblyDrawingId Int?              @map("assembly_drawing_id")
  quantityToProduce Decimal           @map("quantity_to_produce") @db.Decimal(18, 4)
  planningStatus    Int               @default(0) @map("planning_status")
  planningDate      DateTime          @default(now()) @map("planning_date") @db.Timestamp(6)
  planningWorkerId  Int               @map("planning_worker_id")
  note              String?           @map("note") @db.VarChar(255)
  signature         String?           @map("signature") @db.VarChar(30)
  createdAt         DateTime?         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime?         @default(now()) @map("updated_at") @db.Timestamp(6)
  isLocked          Boolean?          @map("is_locked")
  planNumber        String?           @map("plan_number") @db.VarChar(30)
  planDrawingNumber String?           @map("plan_drawing_number") @db.VarChar(20)
  planRevision      String?           @map("plan_revision") @db.VarChar(3)
  assemblyDrawing   Drawing?          @relation(fields: [assemblyDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_plans_assembly")
  items             DrawingPlanItem[]

  @@map("drawing_plans")
}

/// Was: PDM_PlaniranjeStavke
model DrawingPlanItem {
  id                     Int         @id(map: "pk_drawing_plan_items") @default(autoincrement()) @map("id")
  planId                 Int         @map("plan_id")
  procurementDrawingId   Int         @map("procurement_drawing_id")
  itemId                 Int?        @map("item_id")
  quantityPerAssembly    Decimal     @map("quantity_per_assembly") @db.Decimal(18, 4)
  totalRequired          Decimal?    @map("total_required") @db.Decimal(18, 4)
  prevCheckPlanId        Int?        @map("prev_check_plan_id")
  decisionAction         Int         @default(0) @map("decision_action") @db.SmallInt
  manualQuantity         Decimal?    @map("manual_quantity") @db.Decimal(18, 4)
  reserved               Decimal     @default(0) @map("reserved") @db.Decimal(18, 4)
  toProcure              Decimal     @default(0) @map("to_procure") @db.Decimal(18, 4)
  inStock                Decimal?    @map("in_stock") @db.Decimal(18, 4)
  itemName               String?     @map("item_name") @db.VarChar(150)
  itemCatalogNumber      String?     @map("item_catalog_number") @db.VarChar(20)
  itemUnit               String?     @map("item_unit") @db.VarChar(5)
  isManualItem           Boolean     @default(false) @map("is_manual_item")
  excludeFromProcurement Boolean     @default(false) @map("exclude_from_procurement")
  procurementDrawing     Drawing     @relation(fields: [procurementDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_plan_items_drawing")
  plan                   DrawingPlan @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_plan_items_plan")

  @@map("drawing_plan_items")
}

/// Was: SklopoviPDMCrteza
model DrawingAssembly {
  id              Int     @id(map: "pk_drawing_assemblies") @default(autoincrement()) @map("id")
  childDrawingId  Int     @map("child_drawing_id")
  parentDrawingId Int     @map("parent_drawing_id")
  quantity        Int     @default(1) @map("quantity")
  childDrawing    Drawing @relation("DrawingAssemblyChild", fields: [childDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_assemblies_child")
  parentDrawing   Drawing @relation("DrawingAssemblyParent", fields: [parentDrawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_assemblies_parent")

  @@map("drawing_assemblies")
}

/// Was: StatusiCrteza
model DrawingStatus {
  id       Int       @id @map("id")
  name     String    @map("name") @db.VarChar(50)
  drawings Drawing[]

  @@map("drawing_statuses")
}

// ============================================================================
// MRP (Material Requirements Planning) — already English-ish, just normalise
// ============================================================================

/// Was: MRP_Potrebe
model MrpDemand {
  id              Int             @id(map: "pk_mrp_demands") @default(autoincrement()) @map("id")
  projectId       Int             @map("project_id")
  rootDrawingId   Int?            @map("root_drawing_id")
  workerId        Int?            @map("worker_id")
  source          Int             @map("source") @db.SmallInt
  explosionType   Int?            @map("explosion_type") @db.SmallInt
  status          Int             @default(0) @map("status") @db.SmallInt
  demandDate      DateTime        @map("demand_date") @db.Date
  note            String?         @map("note") @db.VarChar(500)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy       String?         @map("created_by") @db.VarChar(20)
  updatedAt       DateTime?       @map("updated_at") @db.Timestamp(6)
  updatedBy       String?         @map("updated_by") @db.VarChar(20)
  plannedQuantity Decimal         @default(0) @map("planned_quantity") @db.Decimal(19, 6)
  planId          Int?            @map("plan_id")
  items           MrpDemandItem[]

  @@map("mrp_demands")
}

/// Was: MRP_PotrebeStavke
model MrpDemandItem {
  id                   Int       @id(map: "pk_mrp_demand_items") @default(autoincrement()) @map("id")
  demandId             Int       @map("demand_id")
  sourceDrawingId      Int?      @map("source_drawing_id")
  procurementDrawingId Int?      @map("procurement_drawing_id")
  itemId               Int?      @map("item_id")
  itemCatalogNumber    String    @map("item_catalog_number") @db.VarChar(100)
  itemName             String    @map("item_name") @db.VarChar(200)
  itemUnit             String    @map("item_unit") @db.VarChar(10)
  itemSource           Int       @map("item_source") @db.SmallInt
  requiredQuantity     Decimal   @map("required_quantity") @db.Decimal(19, 6)
  demandDate           DateTime  @map("demand_date") @db.Date
  leadTimeDays         Int?      @map("lead_time_days")
  procurementDate      DateTime? @map("procurement_date") @db.Date
  note                 String?   @map("note") @db.VarChar(500)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  createdBy            String?   @map("created_by") @db.VarChar(20)
  updatedAt            DateTime? @map("updated_at") @db.Timestamp(6)
  updatedBy            String?   @map("updated_by") @db.VarChar(20)
  supplierId           Int?      @map("supplier_id")
  itemStatus           Int       @default(0) @map("item_status") @db.SmallInt
  reservedQuantity     Decimal   @default(0) @map("reserved_quantity") @db.Decimal(19, 6)
  toProcureQuantity    Decimal   @default(0) @map("to_procure_quantity") @db.Decimal(19, 6)
  demand               MrpDemand @relation(fields: [demandId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mrp_demand_items_demand")

  @@map("mrp_demand_items")
}

/// Was: MRP_StanjeArtikala
model MrpItemStock {
  itemId        Int       @id @map("item_id")
  inStock       Decimal   @default(0) @map("in_stock") @db.Decimal(19, 6)
  reserved      Decimal   @default(0) @map("reserved") @db.Decimal(19, 6)
  name          String?   @map("name") @db.VarChar(200)
  catalogNumber String?   @map("catalog_number") @db.VarChar(100)
  unit          String?   @map("unit") @db.VarChar(20)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("mrp_item_stock")
}

/// Was: MRP_StanjeArtikala_TMP
model MrpItemStockTmp {
  itemId        Int     @id @map("item_id")
  inStock       Decimal @default(0) @map("in_stock") @db.Decimal(19, 6)
  reserved      Decimal @default(0) @map("reserved") @db.Decimal(19, 6)
  name          String? @map("name") @db.VarChar(200)
  catalogNumber String? @map("catalog_number") @db.VarChar(100)
  unit          String? @map("unit") @db.VarChar(20)

  @@map("mrp_item_stock_tmp")
}

/// Was: MRP_SyncStatus
