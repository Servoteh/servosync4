/// Was: PrimopredajaCrteza
model DrawingHandover {
  id                       Int                  @id @default(autoincrement()) @map("id")
  drawingId                Int                  @map("drawing_id")
  handoverDate             DateTime             @map("handover_date") @db.Timestamp(6)
  handoverWorkerId         Int                  @map("handover_worker_id")
  statusId                 Int                  @default(0) @map("status_id")
  statusChangedAt          DateTime?            @map("status_changed_at") @db.Timestamp(6)
  statusChangedById        Int?                 @map("status_changed_by_id")
  statusChangeComment      String?              @map("status_change_comment") @db.VarChar(250)
  launchedAt               DateTime?            @map("launched_at") @db.Timestamp(6)
  launchedById             Int?                 @map("launched_by_id")
  note                     String?              @map("note") @db.VarChar(250)
  signature                String?              @map("signature") @db.VarChar(30)
  createdAt                DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                DateTime?            @default(now()) @map("updated_at") @db.Timestamp(6)
  isLocked                 Boolean?             @default(false) @map("is_locked")
  /// APP-ONLY 2.0 column (no legacy source): technologist picked by the head of
  /// technology when approving the handover — writes the tech process (TP).
  /// Legacy PrimopredajaCrteza is empty and this table becomes ServoSync-owned at
  /// cutover, so extending it is a deliberate, documented deviation from the
  /// "synced tables are cache" rule. 0 = not assigned.
  technologistId           Int                  @default(0) @map("technologist_id")
  /// APP-ONLY provenance (no legacy column source): tRN.IDRN of the source legacy
  /// row — the legacy handover lives as attributes of the tRN row (PrimopredajaCrteza
  /// is empty even on the live MSSQL), so the derivation syncer upserts by this key.
  /// NULL = native 2.0 row (handover-drafts submit). Table is ServoSync-owned, same
  /// precedent as technologist_id above.
  legacyRnId               Int?                 @unique(map: "uq_drawing_handovers_legacy_rn_id") @map("legacy_rn_id")
  /// APP-ONLY audit (no legacy source; same documented precedent as technologist_id):
  /// when the CURRENT technologist was assigned — written by both approve() (head
  /// of technology picks the technologist) and take-over ("Preuzmi izradu", §6.4).
  /// Cleared by return-to-pending together with the technologist undo. Timestamp(6)
  /// deliberately matches the sibling columns of this legacy-shaped table
  /// (BACKEND_RULES Timestamptz rule applies to NEW tables only).
  technologistAssignedAt   DateTime?            @map("technologist_assigned_at") @db.Timestamp(6)
  /// APP-ONLY audit: worker who performed the assignment (approve = head of
  /// technology; take-over = the technologist who took over, self-assigned).
  /// NULL when the acting account has no linked worker.
  technologistAssignedById Int?                 @map("technologist_assigned_by_id")
  /// APP-ONLY (§6.5.1): production deadline entered by the APPROVER (legacy: the
  /// approving engineer enters the deadline, not the launcher). Propagated to
  /// work_orders.production_deadline when the RN is created from this handover;
  /// an explicit launch dueDate overrides it. Nullable (optional until Miljan
  /// confirms it is mandatory, spec §8 #8). Cleared by return-to-pending.
  productionDeadline       DateTime?            @map("production_deadline") @db.Timestamp(6)
  /// APP-ONLY (Miljan t.10): URGENT flag set by the approver when sending the
  /// handover to technologists (legacy: red "HITNO" stickers on the printed TP).
  /// Shown as a badge in handover lists, on the TP card and on the printed RN.
  /// Same ServoSync-owned-table precedent as technologist_id above.
  isUrgent                 Boolean              @default(false) @map("is_urgent")
  drawing                  Drawing              @relation(fields: [drawingId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_handovers_drawing")
  status                   HandoverStatus       @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_handovers_status")
  handoverPdfs             DrawingHandoverPdf[]

  @@map("drawing_handovers")
}

