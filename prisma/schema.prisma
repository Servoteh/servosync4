// ============================================================================
// APPLICATION AUTH & AUDIT
// ----------------------------------------------------------------------------
// These tables do NOT come from BigBit / legacy MSSQL. They are owned by the
// NestJS application layer:
//   - `users`           : application accounts (email + password), distinct
//                         from `workers` (production-floor staff) and
//                         `registered_users` (legacy desktop app registry).
//   - `refresh_tokens`  : JWT refresh-token rotation store.
//   - `audit_log`       : append-only audit trail for write operations and
//                         security events. Designed to survive user deletion
//                         (FK is SetNull + denormalised `actor_username`).
// ============================================================================

/// Application user (NestJS auth). Email + password_hash login.
model User {
  id                  Int                      @id(map: "pk_users") @default(autoincrement()) @map("id")
  email               String                   @unique(map: "uq_users_email") @map("email") @db.VarChar(255)
  passwordHash        String                   @map("password_hash") @db.VarChar(255)
  fullName            String?                  @map("full_name") @db.VarChar(150)
  /// Primary role, lowercase snake_case (catalog: src/common/authz/roles.ts; AUTHZ_UNIFIED.md).
  /// Kept as String (not enum) so new roles can be introduced without a schema migration.
  /// Legacy values "ADMIN"/"USER" are lowercased by the authz_rls_ready migration.
  role                String                   @default("user") @map("role") @db.VarChar(30)
  active              Boolean                  @default(true) @map("active")
  /// Force-change gate (Talas D / D3): admin reset ili invite postavlja true; 2.0 force-change
  /// ekran (R3 FE) ga briše po uspešnoj promeni lozinke. Paritet 1.0 `user_roles.must_change_password`.
  mustChangePassword  Boolean                  @default(false) @map("must_change_password")
  emailVerifiedAt     DateTime?                @map("email_verified_at") @db.Timestamp(6)
  lastLoginAt         DateTime?                @map("last_login_at") @db.Timestamp(6)
  /// Bridge JWT user -> production Worker (definesApproval/definesLaunch, machine_access).
  /// RLS-ready keystone (AUTHZ_UNIFIED §5).
  workerId            Int?                     @map("worker_id")
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamp(6)
  worker              Worker?                  @relation("UserWorker", fields: [workerId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_users_worker")
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  bbSyncLogs          BbSyncLog[]
  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@map("users")
}

/// App-owned role assignment. Supersedes 1.0 `user_roles` (email-based) with userId +
/// scope columns; `managed_sub_department_ids` carries the 1.0 Kadrovska scope.
/// Role values: lowercase catalog in src/common/authz/roles.ts (no DB CHECK by design —
/// BACKEND_RULES §2; assignment endpoint validates via isKnownRole(), guard is default-deny).
model UserRole {
  id                      Int      @id(map: "pk_user_roles") @default(autoincrement()) @map("id")
  userId                  Int      @map("user_id")
  role                    String   @map("role") @db.VarChar(30)
  /// "global" | "project" | "department" | "module"
  scopeType               String   @default("global") @map("scope_type") @db.VarChar(20)
  scopeId                 String?  @map("scope_id") @db.VarChar(64)
  /// 1.0 Kadrovska/prisustvo scope. Semantics: empty/NULL = full scope FOR `menadzment` ONLY
  /// (legacy 1.0 rows); `tim_lider` must have an explicit list (see app_manages_sub_department()).
  managedSubDepartmentIds Int[]    @map("managed_sub_department_ids")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_roles_user")

  @@unique([userId, role, scopeType, scopeId], map: "uq_user_roles")
  @@index([userId], map: "idx_user_roles_user")
  @@map("user_roles")
}

/// Per-user permission override flags (1.0 pattern: readonly/access/hide flags,
/// `finalni_potpisnik`). deny (allow=false) beats role grants; guard applies AFTER role union.
model UserPermissionOverride {
  id     Int     @id(map: "pk_user_permission_overrides") @default(autoincrement()) @map("id")
  userId Int     @map("user_id")
  /// Permission key (src/common/authz/permissions.ts) or named flag, e.g. "finalni_potpisnik".
  key    String  @map("key") @db.VarChar(64)
  allow  Boolean @map("allow")
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_permission_overrides_user")

  @@unique([userId, key], map: "uq_user_permission_overrides")
  @@map("user_permission_overrides")
}

/// JWT refresh token with rotation support.
///
/// - `tokenHash` is a hash of the opaque refresh token (never store raw tokens).
/// - `revokedAt` marks logout / revocation; `expiresAt` is the natural TTL.
/// - `replacedByTokenId` points to the new token after rotation (self-FK).
model RefreshToken {
  id                Int            @id(map: "pk_refresh_tokens") @default(autoincrement()) @map("id")
  userId            Int            @map("user_id")
  tokenHash         String         @unique(map: "uq_refresh_tokens_token_hash") @map("token_hash") @db.VarChar(255)
  expiresAt         DateTime       @map("expires_at") @db.Timestamp(6)
  revokedAt         DateTime?      @map("revoked_at") @db.Timestamp(6)
  replacedByTokenId Int?           @map("replaced_by_token_id")
  userAgent         String?        @map("user_agent") @db.VarChar(500)
  ipAddress         String?        @map("ip_address") @db.VarChar(45)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_tokens_user")
  replacedBy        RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_refresh_tokens_replaced_by")
  replacedTokens    RefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

/// Append-only audit trail.
///
/// `entityId` is intentionally a `String` so it can hold any natural key shape
/// (numeric ids, codes like `"VISA"`, composite keys serialised as strings).
/// `actorUsername` is a denormalised snapshot so the log survives even if the
/// user row is later deleted (FK uses SetNull).
model AuditLog {
  id            Int      @id(map: "pk_audit_log") @default(autoincrement()) @map("id")
  actorUserId   Int?     @map("actor_user_id")
  actorUsername String?  @map("actor_username") @db.VarChar(255)
  action        String   @map("action") @db.VarChar(100)
  entityType    String?  @map("entity_type") @db.VarChar(100)
  entityId      String?  @map("entity_id") @db.VarChar(100)
  beforeData    Json?    @map("before_data")
  afterData     Json?    @map("after_data")
  metadata      Json?    @map("metadata")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  actor         User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_audit_log_actor_user")

  @@index([actorUserId], map: "idx_audit_log_actor_user_id")
  @@index([entityType, entityId], map: "idx_audit_log_entity")
  @@index([createdAt], map: "idx_audit_log_created_at")
  @@map("audit_log")
}

// ============================================================================
// BIGBIT SYNC (application-owned; not legacy BigBit tables)
// ----------------------------------------------------------------------------
// Sprint 1 decision: **approach B** — NestJS service connects to SQL Server
// (BigBit) with a read-only client (e.g. `mssql` / tedious), pulls deltas,
// upserts into Postgres via Prisma. `bb_sync_log` = append-only run history;
// `bb_sync_state` = one bookmark row per sync scope (`entity`) with a JSON
// cursor (shape depends on table: lastModifiedAt, lastId, rowversion, …).
// ============================================================================

/// One row per manual/cron/API sync run (BigBit → Postgres).
model BbSyncLog {
  id                    Int           @id(map: "pk_bb_sync_log") @default(autoincrement()) @map("id")
  startedAt             DateTime      @default(now()) @map("started_at") @db.Timestamp(6)
  finishedAt            DateTime?     @map("finished_at") @db.Timestamp(6)
  /// `running` | `success` | `failed` | `partial` — kept as String (no Prisma enum migration churn).
  status                String        @default("running") @map("status") @db.VarChar(20)
  /// `manual` | `cron` | `api`
  trigger               String        @default("manual") @map("trigger") @db.VarChar(20)
  triggeredByUserId     Int?          @map("triggered_by_user_id")
  /// What was synced, e.g. `customers`, `items`, `all_incremental`.
  entityScope           String?       @map("entity_scope") @db.VarChar(100)
  rowsFetched           Int           @default(0) @map("rows_fetched")
  rowsUpserted          Int           @default(0) @map("rows_upserted")
  rowsSkipped           Int           @default(0) @map("rows_skipped")
  errorMessage          String?       @map("error_message")
  metadata              Json?         @map("metadata")
  triggeredBy           User?         @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_bb_sync_log_triggered_by_user")
  syncStatesLastSuccess BbSyncState[] @relation("BbSyncStateLastSuccessLog")

  @@index([entityScope, startedAt], map: "idx_bb_sync_log_entity_scope_started_at")
  @@index([status, startedAt], map: "idx_bb_sync_log_status_started_at")
  @@map("bb_sync_log")
}

// ============================================================================
// IN-APP NOTIFICATIONS (application-owned)
// ----------------------------------------------------------------------------
// D8 first phase (PLAN_dorade_2026-07-10): the "zvonce" — rows are materialised
// PER RECIPIENT worker at emit time (tech-processes control() on rework/scrap,
// handover-drafts submit()) and read/marked by the notifications module.
// NOT the legacy `notifications` model (Was: Info) above — that one is untouched.
// ============================================================================

/// App-owned (2.0, no legacy source). One row per recipient worker; `recipientWorkerId`
/// references `workers.id` WITHOUT a DB FK on purpose — notification history must not
/// block worker maintenance, and reads resolve workers batch-style anyway (relations.ts).
/// Timestamptz like `work_time_entries` (the other 2.0 app-owned production table).
model AppNotification {
  id                Int       @id(map: "pk_app_notifications") @default(autoincrement()) @map("id")
  /// Kind: 'kontrola.skart' | 'kontrola.dorada' | 'primopredaja.nova' — String, not enum (BACKEND_RULES §2).
  type              String    @map("type") @db.VarChar(40)
  /// Fully rendered Serbian UI message (composed at emit time).
  message           String    @map("message") @db.VarChar(500)
  /// Referenced table for UI navigation, e.g. 'work_orders' | 'handover_drafts'.
  refTable          String?   @map("ref_table") @db.VarChar(40)
  refId             Int?      @map("ref_id")
  recipientWorkerId Int       @map("recipient_worker_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt            DateTime? @map("read_at") @db.Timestamptz(6)

  @@index([recipientWorkerId, readAt, createdAt(sort: Desc)], map: "idx_app_notifications_recipient_read_created")
  @@map("app_notifications")
}

/// App-owned (2.0, ODLUKE #8 + Miljan t.7). CAM/programiranje status po poziciji
/// (RN): jedan red po `workOrderId`. Pozicija „zahteva CAM" se izvodi iz rutinga
/// (operacija sa `operations.usesPriority=true`) — ovde se pamti SAMO da li je CAM
/// završen + audit ko/kada (JWT worker). `workOrderId` bez DB FK (batch-resolve,
/// isti razlog kao AppNotification). Timestamptz kao ostale 2.0 app-owned tabele.
model CncProgram {
  id                  Int       @id(map: "pk_cnc_programs") @default(autoincrement()) @map("id")
  workOrderId         Int       @map("work_order_id")
  isDone              Boolean   @default(false) @map("is_done")
  /// Radnik (JWT worker_id) koji je čekirao „CAM završen"; NULL kad nije završeno.
  completedByWorkerId Int?      @map("completed_by_worker_id")
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)
  note                String?   @map("note") @db.VarChar(500)
  /// CAM red (prioritizacija prevlačenjem — Miljan/Nikola/Jovica). Rang 1..N nad
  /// rangiranim pozicijama; NULL = nerangirana. Renumeracija bez rupa u servisu.
  queueOrder          Int?      @map("queue_order")
  /// Radnik (svež users.worker_id lookup) koji je poslednji promenio redosled.
  queueSetByWorkerId  Int?      @map("queue_set_by_worker_id")
  queueSetAt          DateTime? @map("queue_set_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workOrderId], map: "uq_cnc_programs_work_order")
  @@map("cnc_programs")
}

/// App-owned (2.0). Izveštaj o neusaglašenosti — digitalizacija Excel evidencija
/// „Škart"/„Dorada" (MODULE_SPEC_kontrola_kvaliteta §4). Broj (NNN/YY) se dodeljuje
/// TEK pri potvrdi (draft: report_number = NULL) → obrisan lažni draft ne pravi rupu
/// u sekvenci. Meki FK-ovi ka work_orders/tech_processes/workers su BEZ DB constrainta
/// (batch-resolve, legacy orphan); jedini pravi FK je nonconformity_workers.report_id.
/// Timestamptz kao ostale 2.0 app-owned tabele (BACKEND_RULES §11.5). NAPOMENA: partial
/// UNIQUE (type, report_number) WHERE report_number IS NOT NULL postoji SAMO u migraciji —
/// Prisma šema ne može izraziti partial unique (WHERE predikat), pa @@unique namerno izostaje.
model NonconformityReport {
  id                  Int                   @id(map: "pk_nonconformity_reports") @default(autoincrement()) @map("id")
  /// 1 = dorada, 2 = škart (poklapa se sa part_quality REWORK/SCRAP).
  type                Int                   @map("type") @db.SmallInt
  /// „028/26" — dodeljuje server pri potvrdi (sekvenca po tip+godina); NULL dok je draft.
  reportNumber        String?               @map("report_number") @db.VarChar(20)
  reportYear          Int                   @map("report_year")
  reportDate          DateTime              @map("report_date") @db.Timestamptz(6)
  /// 0 = draft (auto iz kioska / ručni unos, čeka potvrdu), 1 = potvrđen.
  status              Int                   @default(0) @map("status") @db.SmallInt
  workOrderId         Int?                  @map("work_order_id")
  identNumber         String?               @map("ident_number") @db.VarChar(50)
  sourceTechProcessId Int?                  @map("source_tech_process_id")
  drawingNumber       String?               @map("drawing_number") @db.VarChar(100)
  partName            String?               @map("part_name") @db.VarChar(255)
  customerName        String?               @map("customer_name") @db.VarChar(255)
  quantity            Int                   @map("quantity")
  defectDescription   String                @default("") @map("defect_description")
  cause               String?               @map("cause")
  workUnit            String?               @map("work_unit") @db.VarChar(120)
  culpritText         String?               @map("culprit_text") @db.VarChar(255)
  materialCostNote    String?               @map("material_cost_note") @db.VarChar(255)
  coopCostNote        String?               @map("coop_cost_note") @db.VarChar(255)
  spentHoursText      String?               @map("spent_hours_text") @db.VarChar(50)
  spentHours          Decimal?              @map("spent_hours") @db.Decimal(10, 3)
  note                String?               @map("note")
  preventiveMeasures  String?               @map("preventive_measures")
  extra               String?               @map("extra") @db.VarChar(255)
  raisedByWorkerId    Int?                  @map("raised_by_worker_id")
  createdByUserId     Int?                  @map("created_by_user_id")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  culpritWorkers      NonconformityWorker[]
  documents           QualityDocument[]

  @@index([type, status], map: "idx_nonconformity_reports_type_status")
  @@index([reportYear], map: "idx_nonconformity_reports_year")
  @@index([workOrderId], map: "idx_nonconformity_reports_work_order")
  @@map("nonconformity_reports")
}

/// App-owned (2.0). Izvršioci-radnici (M:N) po izveštaju — puni „Moje neusaglašenosti"
/// u Moj profil (K3). `workerId` je meki FK (batch-resolve, kao ostatak sheme); `reportId`
/// je PRAVI FK (obe tabele 2.0 native) sa ON DELETE CASCADE.
model NonconformityWorker {
  id       Int                 @id(map: "pk_nonconformity_workers") @default(autoincrement()) @map("id")
  reportId Int                 @map("report_id")
  workerId Int                 @map("worker_id")
  report   NonconformityReport @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_nonconformity_workers_report")

  @@unique([reportId, workerId], map: "uq_nonconformity_workers_report_worker")
  @@index([workerId], map: "idx_nonconformity_workers_worker")
  @@map("nonconformity_workers")
}

/// App-owned (2.0). QC dokumenti — skenirani nalozi, kontrolna dokumentacija, foto sa
/// tableta/telefona (MODULE_SPEC_kontrola_kvaliteta §K4-UPLOAD). ODLUKA Nenad 15.07: NEMA
/// share/mount — sadržaj se UPLOADUJE kroz aplikaciju i čuva u `content` (bytea), presedan
/// `drawing_pdfs`. `reportId` je PRAVI FK → nonconformity_reports (ON DELETE SET NULL: brisanje
/// drafta ne briše arhivski dokument). `techProcessId`/`workOrderId`/`identNumber` su MEKI
/// (bez FK — legacy lanac, batch-resolve/pretraga po RN). Dokument SME biti i nevezan (arhivski).
model QualityDocument {
  id               Int                  @id(map: "pk_quality_documents") @default(autoincrement()) @map("id")
  reportId         Int?                 @map("report_id")
  techProcessId    Int?                 @map("tech_process_id")
  workOrderId      Int?                 @map("work_order_id")
  identNumber      String?              @map("ident_number") @db.VarChar(50)
  fileName         String               @map("file_name") @db.VarChar(255)
  contentType      String               @map("content_type") @db.VarChar(100)
  sizeKb           Int                  @map("size_kb")
  content          Bytes                @map("content")
  uploadedByUserId Int?                 @map("uploaded_by_user_id")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  report           NonconformityReport? @relation(fields: [reportId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_quality_documents_report")

  @@index([reportId], map: "idx_quality_documents_report")
  @@index([techProcessId], map: "idx_quality_documents_tech_process")
  @@index([identNumber], map: "idx_quality_documents_ident")
  @@index([createdAt], map: "idx_quality_documents_created")
  @@map("quality_documents")
}

/// Incremental sync cursor per logical scope (`entity` = stable key, e.g. `customers`).
model BbSyncState {
  entity               String     @id(map: "pk_bb_sync_state") @map("entity") @db.VarChar(100)
  /// Opaque cursor — e.g. `{ "lastModifiedAt": "...", "lastId": 123 }` or `{ "lastRowversion": "..." }`.
  cursor               Json?      @map("cursor")
  lastSuccessAt        DateTime?  @map("last_success_at") @db.Timestamp(6)
  lastAttemptAt        DateTime?  @map("last_attempt_at") @db.Timestamp(6)
  lastErrorMessage     String?    @map("last_error_message")
  lastSuccessSyncLogId Int?       @map("last_success_sync_log_id")
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  lastSuccessSyncLog   BbSyncLog? @relation("BbSyncStateLastSuccessLog", fields: [lastSuccessSyncLogId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_bb_sync_state_last_success_log")

  @@map("bb_sync_state")
}
