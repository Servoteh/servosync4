// ServoSync 3.0 — sy15 (1.0) baza: Reversi pilot (MODULE_SPEC_reversi.md).
// GENERISANO iz zive sy15 information_schema 2026-07-10 — NE menjaj rucno bez re-verifikacije.
// Tabele OSTAJU u sy15 bazi (spec §0): ovo je drugi datasource, NE deo glavne 2.0 seme.
// Uuid PK se ZADRZAVA (1.0 poreklo; BACKEND_RULES §2 "id nije uuid" vazi za QBigTehn legacy port).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma-sy15/client"
}

datasource db {
  provider = "postgresql"
  url      = env("SY15_DATABASE_URL")
}

model RevTool {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  oznaka String
  naziv String
  serijskiBroj String? @map("serijski_broj")
  datumKupovine DateTime? @map("datum_kupovine") @db.Date
  status String @default("active")
  napomena String?
  locItemRefId String? @map("loc_item_ref_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy String? @map("created_by") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  bigtehnSifraArtikla Int? @map("bigtehn_sifra_artikla")
  /// NOT NULL in DB, assigned by the rev_tools_before_insert_barcode trigger —
  /// dbgenerated() makes it optional on create (bulkImportTools inserts without it).
  barcode String @default(dbgenerated())
  subgroupId String? @map("subgroup_id") @db.Uuid
  isQuantity Boolean @default(false) @map("is_quantity")
  totalQty Int @default(1) @map("total_qty")
  isConsumable Boolean @default(false) @map("is_consumable")
  minStockQty Int? @map("min_stock_qty")
  maxStockQty Int? @map("max_stock_qty")
  subsubgroupId String? @map("subsubgroup_id") @db.Uuid
  garancijaDo DateTime? @map("garancija_do") @db.Date
  garancijaNapomena String? @map("garancija_napomena")
  imaPunjac Boolean @default(false) @map("ima_punjac")
  punjacSerijski String? @map("punjac_serijski")
  otpisDatum DateTime? @map("otpis_datum") @db.Date
  otpisRazlog String? @map("otpis_razlog")
  otpisBy String? @map("otpis_by") @db.Uuid
  nabavnaVrednost Decimal? @map("nabavna_vrednost") @db.Decimal
  @@unique([locItemRefId], map: "rev_tools_loc_item_ref_id_key")
  @@map("rev_tools")
}

model RevDocument {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  docNumber String @map("doc_number")
  docType String @map("doc_type")
  recipientType String @map("recipient_type")
  recipientEmployeeId String? @map("recipient_employee_id") @db.Uuid
  recipientEmployeeName String? @map("recipient_employee_name")
  recipientDepartment String? @map("recipient_department")
  recipientCompanyName String? @map("recipient_company_name")
  recipientCompanyPib String? @map("recipient_company_pib")
  recipientLocId String? @map("recipient_loc_id") @db.Uuid
  expectedReturnDate DateTime? @map("expected_return_date") @db.Date
  issuedAt DateTime @default(now()) @map("issued_at") @db.Timestamptz(6)
  issuedBy String @map("issued_by") @db.Uuid
  status String @default("OPEN")
  returnConfirmedBy String? @map("return_confirmed_by") @db.Uuid
  returnConfirmedAt DateTime? @map("return_confirmed_at") @db.Timestamptz(6)
  returnNotes String? @map("return_notes")
  pdfStoragePath String? @map("pdf_storage_path")
  pdfGeneratedAt DateTime? @map("pdf_generated_at") @db.Timestamptz(6)
  napomena String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  recipientMachineCode String? @map("recipient_machine_code")
  issuedToEmployeeId String? @map("issued_to_employee_id") @db.Uuid
  issuedToEmployeeName String? @map("issued_to_employee_name")
  bulkImportLegacyKey String? @map("bulk_import_legacy_key")
  @@unique([docNumber], map: "rev_documents_doc_number_key")
  @@map("rev_documents")
}

