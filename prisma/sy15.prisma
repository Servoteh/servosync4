model Sastanak {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tip String @default("sedmicni")
  naslov String
  datum DateTime @db.Date
  vreme DateTime? @db.Time(6)
  mesto String? @default("")
  projekatId String? @map("projekat_id") @db.Uuid
  vodioEmail String? @map("vodio_email")
  vodioLabel String? @map("vodio_label")
  zapisnicarEmail String? @map("zapisnicar_email")
  zapisnicarLabel String? @map("zapisnicar_label")
  status String @default("planiran")
  zakljucanAt DateTime? @map("zakljucan_at") @db.Timestamptz(6)
  zakljucanByEmail String? @map("zakljucan_by_email")
  napomena String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdByEmail String? @map("created_by_email")
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  pozivnicePoslateAt DateTime? @map("pozivnice_poslate_at") @db.Timestamptz(6)
  @@map("sastanci")
}

model SastanakUcesnik {
  sastanakId String @map("sastanak_id") @db.Uuid
