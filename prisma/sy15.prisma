// ---- Podešavanja: RBAC + matični (spec §1/§2.2/§2.3) ----

/// 1.0 email-based user_roles (razlicito od 2.0 `UserRole` u schema.prisma — FK-based).
/// Nullable niz-kolone `managed_departments`/`managed_sub_department_ids` se NE citaju
/// kroz `tx.userRoleSy15.findMany` (Prisma ne podrzava nullable scalar-liste — NULL red bi
/// pao pri deserijalizaciji); Podešavanja ih cita kroz $queryRaw (row_to_json). Kolone su
/// deklarisane radi tacnosti seme; citaju se raw. Scope (managedSubDepartmentIds) i
/// override-kolone (plan_montaze_readonly/kadrovska_access/kadrovska_hide_contracts) su
/// data-migracija u R2 (matrica #44) — R1 samo cita.
model UserRoleSy15 {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email String
  role String
  projectId String? @map("project_id") @db.Uuid
  isActive Boolean? @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  fullName String? @map("full_name")
  team String?
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  createdBy String? @map("created_by")
  mustChangePassword Boolean? @default(false) @map("must_change_password")
  userId String? @map("user_id") @db.Uuid
  managedDepartments String[] @map("managed_departments")
  managedSubDepartmentIds Int[] @map("managed_sub_department_ids")
  planMontazeReadonly Boolean @default(false) @map("plan_montaze_readonly")
  kadrovskaAccess Boolean @default(false) @map("kadrovska_access")
  kadrovskaHideContracts Boolean @default(false) @map("kadrovska_hide_contracts")
  @@map("user_roles")
}

