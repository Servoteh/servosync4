  priprema String?
  rsvpStatus String? @map("rsvp_status")
  rsvpAt DateTime? @map("rsvp_at") @db.Timestamptz(6)
  /// TAJNA magic-linka — NIKAD ne izlagati kroz API (servisi biraju kolone eksplicitno).
  rsvpToken String @default(dbgenerated("gen_random_uuid()")) @map("rsvp_token") @db.Uuid
  @@id([sastanakId, email])
  @@map("sastanak_ucesnici")
}

