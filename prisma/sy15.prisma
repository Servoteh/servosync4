  @@map("pb_task_vrsta")
}

enum PbPrioritet {
  Visok   @map("Visok")
  Srednji @map("Srednji")
  Nizak   @map("Nizak")
  @@map("pb_prioritet")
}

enum PbTaskStatus {
  NijePocelo @map("Nije počelo")
