# Kopiraj u .env.production pre `npm run build` (ili postavi kao build env var).
# API base se bira U RUNTIME-U u browseru (src/api/client.ts): preko Cloudflare-a → Tunnel,
# na LAN-u → http://<isti-host>:3000/api. Ova promenljiva je samo fallback bez window-a
# (prerender/testovi); menjanje ne utiče na browser. LAN override: public/config.js.
NEXT_PUBLIC_API_URL=https://api.servosync2.servoteh.com/api

# Label-proxy za termalnu štampu nalepnica (MODULE_SPEC_kontrola §6). Lokalni Node
# servis na pogonskom RAČUNARU koji piše RAW TSPL2 u TCP 9100 na TSC ML340P
# (servoteh-plan-montaze/tools/label-proxy). Konfiguriše se PO TERMINALU; ako je prazno,
# kiosk ne štampa (javi „proxy nije podešen"). Primer: http://localhost:8765/print
NEXT_PUBLIC_LABEL_PROXY_URL=
