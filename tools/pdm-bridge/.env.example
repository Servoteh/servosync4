# ServoSync PDM bridge — kopiraj u .env pored skripte: copy .env.example .env
# Pokretanje: node --env-file=.env pdm-bridge.mjs   (Node >= 20.6, preporuka 22 LTS).
# Skripta ima i sopstveni fallback: ako --env-file nije prosleđen, sama učitava
# .env koji stoji PORED NJE (nikad ne pregazi već postavljene env promenljive).

# Backend API — LAN (isti origin kao front) ili preko Cloudflare tunela:
PDM_BRIDGE_API_BASE=http://192.168.64.28:3000/api
# PDM_BRIDGE_API_BASE=https://api.servosync2.servoteh.com/api

# Servisni nalog — rola mora nositi permisiju `pdm.import` (AUTHZ_ENFORCE=true je
# živ na prod-u; nose je role `admin` i `sef` — servisnom nalogu daj `sef`,
# vidi README §Servisni nalog).
PDM_BRIDGE_EMAIL=
PDM_BRIDGE_PASSWORD=

# Folderi koje legacy 10-min skripte i danas prazne (UNC putanje). Windows nalog
# koji pokreće Task mora imati read pravo na oba; u aktivnom modu i write/move.
PDM_BRIDGE_XML_DIR=\\<bigbit-server>\PDMExport\XML
PDM_BRIDGE_PDF_DIR=\\pdm-pdf\VASADATA

# passive (default) = fajlove NE pomera i NE briše — legacy skripte ih i dalje nose.
# active = TEK NA CUTOVER (legacy 10-min skripte ugašene!): posle odgovora fajl se
# premešta u Importovano\ (uspeh) odnosno Neuspelo\ (odbijeno) — paritet PremestiXMLFile.
PDM_BRIDGE_MODE=passive

# Samo aktivni mod, važi za XML folder (default: {XML_DIR}\Importovano i
# {XML_DIR}\Neuspelo — legacy imena iz F_PDM_XMLFolderImportovano/Neuspelo).
# PDF u aktivnom modu uvek ide u {PDF_DIR}\Importovano i {PDF_DIR}\Neuspelo.
#PDM_BRIDGE_IMPORTED_DIR=
#PDM_BRIDGE_FAILED_DIR=

# Preskoči fajl mlađi od N sekundi (zaštita od fajla koji se još piše).
PDM_BRIDGE_MIN_AGE_S=30

# Maksimalna veličina fajla u MB — veći se trajno preskaču (WARN u logu).
PDM_BRIDGE_MAX_MB=50

# Lokalni state (dedup poslatog) i log (append + ispis u konzolu).
# Relativne putanje se razrešavaju od foldera skripte, ne od radnog foldera.
PDM_BRIDGE_STATE_FILE=./pdm-bridge.state.json
PDM_BRIDGE_LOG_FILE=./pdm-bridge.log
