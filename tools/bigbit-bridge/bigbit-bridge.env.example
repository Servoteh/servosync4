# ServoSync BigBit bridge — kopiraj u bigbit-bridge.env pored skripte:
#   copy bigbit-bridge.env.example bigbit-bridge.env
# Pokretanje: powershell -NoProfile -ExecutionPolicy Bypass -File bigbit-bridge.ps1
# Promenljive iz procesa (environment) PREGAZE vrednosti iz ovog fajla.
# NAPOMENA o kodiranju: ako neka vrednost sadrži naša slova (š, đ, č…), sačuvaj
# fajl kao "UTF-8 with BOM" da bi ga PowerShell 5.1 ispravno pročitao.

# --- BigBit izvor (UNC putanje na BigBit serveru) ---
# .mdb i .MDW se NIKAD ne otvaraju direktno — skripta ih prvo KOPIRA u lokalni
# temp pa čita kopiju (original drži otvorenim BigBit aplikacija; vidi README).
BB_BRIDGE_MDB_UNC=\\<bigbit-server>\<share>\BB_T.mdb
BB_BRIDGE_MDW_UNC=\\<bigbit-server>\<share>\BIGBIT.MDW

# --- ULS (Access workgroup security) nalog ---
# ⚠️ Nalog MORA imati READ pravo u ULS-u: admin/telefon NEMA read!
# Aplikativni nalog je "Slavisa" (lozinka se nabavlja od Negovana).
# Skripta na startu radi SELECT COUNT(*) probu i pada sa jasnom porukom bez read prava.
BB_BRIDGE_ULS_USER=Slavisa
BB_BRIDGE_ULS_PASSWORD=

# --- PostgreSQL (kontejner servosync-pg na ubuntusrv 192.168.64.28) ---
# ⚠️ Port 5432 mora biti izložen na LAN (bind 192.168.64.28) SAMO za Srv-all
# (192.168.64.27) — još NIJE izloženo; vidi README §Preduslovi na ubuntusrv.
# Rola bb_sync ima GRANT samo na ciljne tabele (SQL u README-u).
BB_BRIDGE_PG_HOST=192.168.64.28
BB_BRIDGE_PG_PORT=5432
BB_BRIDGE_PG_DB=servosync
BB_BRIDGE_PG_USER=bb_sync
BB_BRIDGE_PG_PASSWORD=

# --- Alati / putanje (opciono) ---
# psql.exe — prazno = auto-detekcija (PATH, pa C:\Program Files\PostgreSQL\<ver>\bin).
BB_BRIDGE_PSQL_EXE=
# Lokalni temp za kopiju .mdb/.MDW + CSV/SQL po run-u (default: %TEMP%\bigbit-bridge).
# Mora imati dovoljno mesta za celu .mdb kopiju (do 2 GB — Jet limit).
BB_BRIDGE_TEMP_DIR=
# Log fajl (append; default: bigbit-bridge.log pored skripte).
BB_BRIDGE_LOG_FILE=
