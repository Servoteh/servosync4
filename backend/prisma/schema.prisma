generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BBDefUser {
  UserName      String         @id(map: "aaaaaBBDefUser_PK") @db.VarChar(20)
  DefaultGodina Int?           @default(dbgenerated("(EXTRACT(year FROM CURRENT_DATE))::integer"))
  DefaultOJ     Int?           @default(0)
  DefaultOD     Int?           @default(0)
  UnlockGodina  Boolean?       @default(false)
  UnlockOJ      Boolean?       @default(false)
  UnlockOD      Boolean?       @default(false)
  Level         Int?           @default(0) @db.SmallInt
  MaxLevel      Int?           @default(0) @db.SmallInt
  BBOdeljenja   BBOdeljenja?   @relation(fields: [DefaultOD], references: [OD], onDelete: NoAction, onUpdate: NoAction, map: "FK_BBDefUser_BBOdeljenja")
  BBOrgJedinice BBOrgJedinice? @relation(fields: [DefaultOJ], references: [OJ], onDelete: NoAction, onUpdate: NoAction, map: "FK_BBDefUser_BBOrgJedinice")
}

model BBOdeljenja {
  OD        Int         @id(map: "aaaaaBBOdeljenja_PK") @default(autoincrement())
  OznakaOD  String      @db.VarChar(10)
  OpisOD    String      @db.VarChar(50)
  BBDefUser BBDefUser[]
}

model BBOrgJedinice {
  OJ        Int         @id(map: "aaaaaBBOrgJedinice_PK") @default(autoincrement())
  OznakaOJ  String      @db.VarChar(10)
  OpisOJ    String      @db.VarChar(50)
  BBDefUser BBDefUser[]
}

model BBPravaPristupa {
  ID           Int     @id(map: "aaaaaBBPravaPristupa_PK") @default(autoincrement())
  ImeUsera     String  @db.VarChar(20)
  ImeForme     String  @db.VarChar(50)
  ImeKontrole  String  @db.VarChar(50)
  Visible      Boolean @default(true)
  Locked       Boolean @default(false)
  Enabled      Boolean @default(true)
  Vrednost     String? @db.VarChar(250)
  RecordSource String?
  Filter       String? @db.VarChar(250)
}

model CFG_Global {
  IDFirma   Int     @default(0)
  Parametar String  @db.VarChar(120)
  Vrednost  String?
  Tip       String? @db.VarChar(20)
  Opis      String? @db.VarChar(100)

  @@id([IDFirma, Parametar], map: "CFG_Global_PK")
}

model CFG_Sys {
  Parametar String    @id(map: "PK_CFG_Sys") @db.VarChar(120)
  Vrednost  String?   @db.VarChar(50)
  Tip       String?   @db.VarChar(20)
  Opis      String?   @db.VarChar(255)
  DIVUnos   DateTime? @default(now()) @db.Timestamp(6)
}

model Cenovnik {
  ID              Int       @id(map: "PK_Cenovnik") @default(autoincrement())
  Sifra_artikla   Int       @default(0) @map("Sifra artikla")
  Vrsta_dokumenta String    @map("Vrsta dokumenta") @db.VarChar(5)
  Cena            Float?    @default(0)
  Tarifa          String    @db.VarChar(5)
  CenaBezPDV      Decimal?  @default(0) @db.Decimal(19, 4)
  Taksa           Float?    @default(0)
  Prn             Boolean?  @default(true)
  CenaSaPDV       Decimal?  @default(0) @db.Decimal(19, 4)
  CheckCenaSaPDV  Boolean?  @default(false)
  ZakCen          Boolean?  @default(false)
  R_Artikli       R_Artikli @relation(fields: [Sifra_artikla], references: [Sifra_artikla], onDelete: NoAction, onUpdate: NoAction, map: "Cenovnik_FK00")
  R_Tarife        R_Tarife  @relation(fields: [Tarifa], references: [Tarifa], onDelete: NoAction, onUpdate: NoAction, map: "Cenovnik_FK01")
}

model Info {
  ID                 Int       @id(map: "aaaaaInfo_PK") @default(0)
