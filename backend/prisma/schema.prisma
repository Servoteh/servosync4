  handover   DrawingHandover @relation(fields: [handoverId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drawing_handover_pdfs_handover")

  @@unique([handoverId, fileLink], map: "uq_drawing_handover_pdfs_handover_link")
  @@map("drawing_handover_pdfs")
}

