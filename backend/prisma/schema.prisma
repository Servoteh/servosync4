  material              String                     @map("material") @db.VarChar(250)
  materialDimension     String                     @map("material_dimension") @db.VarChar(150)
  unit                  String                     @map("unit") @db.VarChar(50)
  processedPartWeight   Float?                     @default(0) @map("processed_part_weight")
  note                  String?                    @map("note")
  status                Boolean?                   @default(false) @map("status")
  productionDeadline    DateTime?                  @map("production_deadline") @db.Timestamp(6)
  createdAt             DateTime                   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime                   @default(now()) @map("updated_at") @db.Timestamp(6)
  workerId              Int                        @default(0) @map("worker_id")
  isLocked              Boolean?                   @default(false) @map("is_locked")
  signature             String?                    @map("signature") @db.VarChar(50)
  printTimer            Int?                       @default(0) @map("print_timer")
  parentDrawingRef      String?                    @map("parent_drawing_ref") @db.VarChar(100)
  qualityTypeId         Int                        @default(0) @map("quality_type_id")
  revision              String                     @default("A") @map("revision") @db.VarChar(3)
  drawingHandoverId     Int                        @default(0) @map("drawing_handover_id")
  drawingId             Int                        @default(0) @map("drawing_id")
  handoverStatusId      Int                        @default(3) @map("handover_status_id")
  handoverWorkerId      Int                        @default(0) @map("handover_worker_id")
  /// APP-ONLY (Miljan t.2, ODLUKE #35): dorada/škart child RN → izvorni RN
  /// (work_orders.id). Strukturisano poreklo umesto samo `-D`/`-S` sufiksa u
  /// identNumber-u — omogućava praćenje toka proizvodnje od izvornog naloga.
  /// 0 = nema (ručni unos, clone-variant, bulk-clone). Popunjava ga rework().
  parentWorkOrderId     Int                        @default(0) @map("parent_work_order_id")
  launches              WorkOrderLaunch[]
  machinedParts         WorkOrderMachinedPart[]
  blanks                WorkOrderBlank[]
  nonStandardParts      WorkOrderNonstandardPart[]
  handoverWorker        Worker                     @relation("WorkOrderHandoverWorker", fields: [handoverWorkerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_work_orders_handover_worker")
  handoverStatus        HandoverStatus             @relation(fields: [handoverStatusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_work_orders_handover_status")
  worker                Worker                     @relation("WorkOrderWorker", fields: [workerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_work_orders_worker")
  qualityType           PartQualityType            @relation(fields: [qualityTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_work_orders_quality_type")
  components            WorkOrderComponent[]
  itemComponents        WorkOrderItemComponent[]
  approvals             WorkOrderApproval[]
  operations            WorkOrderOperation[]

  /// Triple = business identity of a work order (tech_processes bookings and the
  /// RNZ barcode bind to it). D5 clone-variant relies on this as the DB net for
  /// MAX(variant)+1 races/collisions (prod verified duplicate-free 2026-07-11).
  @@unique([projectId, identNumber, variant], map: "uq_work_orders_project_ident_variant")
  /// R1 (PDM crtež↔RN): brzo poklapanje po drawing_id (EXISTS filter + batch
  /// resolveWorkOrderRefs `drawingId IN`). Grana poklapanja po broju koristi
  /// funkcionalni indeks lower(drawing_number) — raw-only u migraciji (Prisma
  /// ne ume izraz-indeks u @@index).
  @@index([drawingId], map: "idx_work_orders_drawing_id")
  @@map("work_orders")
}

