/// App-owned (2.0, plan §4.2 (c), F5b). Audit premeštaja operacije na drugu mašinu (samo forsirani
/// premeštaji — group-mismatch koji je admin/menadžment probio). Zamena za sy15
/// `production_reassign_audit` (COPY 1:1). Idempotencija po (client_event_uuid, line_id) — ISTA
/// semantika kao sy15 `ON CONFLICT (client_event_uuid, line_id) DO NOTHING`. No-client-write u sy15;
/// u 2.0 upisuje BE reassign servis (F5b-1c). Meki ref-ovi → work_orders / work_order_operations.
model PlanProizvodnjeReassignAudit {
  id              Int      @id(map: "pk_plan_proizvodnje_reassign_audit") @default(autoincrement()) @map("id")
  workOrderId     Int      @map("work_order_id")
  lineId          Int      @map("line_id")
  /// Ko je forsirao (sy15 `actor_email` = current_user_email()); tekst, verbatim.
  actorEmail      String?  @map("actor_email")
  /// sy15 `source_machine`.
  fromMachineCode String?  @map("from_machine_code") @db.VarChar(50)
  /// sy15 `target_machine`.
  toMachineCode   String?  @map("to_machine_code") @db.VarChar(50)
  sourceGroup     String?  @map("source_group") @db.VarChar(50)
  targetGroup     String?  @map("target_group") @db.VarChar(50)
  /// True = forsiran premeštaj. sy15 audit red postoji SAMO za forsirane → default true.
  forced          Boolean  @default(true) @map("forced")
  forceReason     String?  @map("force_reason")
  /// Klijentski event uuid (idempotencija dupliranog submita); null dozvoljen (stariji sy15 poziv
  /// bez uuid-a). PG tretira NULL kao različit → jedinstvenost se ne enforce-uje za null (kao sy15).
  clientEventUuid String?  @map("client_event_uuid") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([clientEventUuid, lineId], map: "uq_plan_proizvodnje_reassign_client_event_line")
  @@index([workOrderId], map: "idx_plan_proizvodnje_reassign_work_order")
  @@map("plan_proizvodnje_reassign_audit")
}

