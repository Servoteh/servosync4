/// App-owned (2.0, plan §4.2 (e), F5b, odluka M1). Skica planera uz operaciju — PDF u bazi (bytea,
/// obrazac `drawing_pdfs.pdf_binary`; glavna baza nema object storage). Zamena za sy15
/// `production_drawings` (koja je koristila storage bucket) — `storagePath` je zamenjen `pdfBinary`.
/// Soft-delete preko `deletedAt`. Meki ref-ovi → work_orders / work_order_operations (bez DB FK).
model PlanProizvodnjeDrawing {
  id           Int       @id(map: "pk_plan_proizvodnje_drawings") @default(autoincrement()) @map("id")
  /// sy15 provenance (production_drawings.id — bigint): idempotentan re-import. NULL za native 2.0.
  legacySy15Id BigInt?   @unique(map: "uq_plan_proizvodnje_drawings_legacy_sy15") @map("legacy_sy15_id")
  workOrderId  Int       @map("work_order_id")
  /// Meki ref → work_order_operations.id; null = skica na nivou RN-a.
  lineId       Int?      @map("line_id")
  fileName     String    @map("file_name") @db.VarChar(255)
  contentType  String?   @map("content_type") @db.VarChar(100)
