/// Was: Kontni plan  — kontni plan (1389 konta, seed iz bigbit_raw.kontni_plan na cutover)
model Account {
  code            String   @id(map: "pk_accounts") @map("code") @db.VarChar(10) // Konto
  name            String   @map("name") @db.VarChar(255) // Opis
  longDescription String?  @map("long_description") // Dugacki opis
  accountClass    Int      @map("account_class") // izvedeno iz prve cifre (0-9)
  allowsAnalytics Boolean  @default(false) @map("allows_analytics") // Dozvoljen unos analitike
  codebookFile    String?  @map("codebook_file") @db.VarChar(64) // Fajl sifara
  foreignAccount  String?  @map("foreign_account") @db.VarChar(10) // InoKonto
