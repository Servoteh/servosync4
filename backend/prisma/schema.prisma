// ============================================================================
// APPLICATION AUTH & AUDIT
// ----------------------------------------------------------------------------
// These tables do NOT come from BigBit / legacy MSSQL. They are owned by the
// NestJS application layer:
//   - `users`           : application accounts (email + password), distinct
//                         from `workers` (production-floor staff) and
//                         `registered_users` (legacy desktop app registry).
//   - `refresh_tokens`  : JWT refresh-token rotation store.
//   - `audit_log`       : append-only audit trail for write operations and
//                         security events. Designed to survive user deletion
//                         (FK is SetNull + denormalised `actor_username`).
// ============================================================================

/// Application user (NestJS auth). Email + password_hash login.
model User {
  id                  Int                      @id(map: "pk_users") @default(autoincrement()) @map("id")
  email               String                   @unique(map: "uq_users_email") @map("email") @db.VarChar(255)
  passwordHash        String                   @map("password_hash") @db.VarChar(255)
  fullName            String?                  @map("full_name") @db.VarChar(150)
  /// Primary role, lowercase snake_case (catalog: src/common/authz/roles.ts; AUTHZ_UNIFIED.md).
  /// Kept as String (not enum) so new roles can be introduced without a schema migration.
  /// Legacy values "ADMIN"/"USER" are lowercased by the authz_rls_ready migration.
  role                String                   @default("user") @map("role") @db.VarChar(30)
  active              Boolean                  @default(true) @map("active")
  /// Force-change gate (Talas D / D3): admin reset ili invite postavlja true; 2.0 force-change
  /// ekran (R3 FE) ga briše po uspešnoj promeni lozinke. Paritet 1.0 `user_roles.must_change_password`.
  mustChangePassword  Boolean                  @default(false) @map("must_change_password")
  emailVerifiedAt     DateTime?                @map("email_verified_at") @db.Timestamp(6)
  lastLoginAt         DateTime?                @map("last_login_at") @db.Timestamp(6)
  /// Bridge JWT user -> production Worker (definesApproval/definesLaunch, machine_access).
  /// RLS-ready keystone (AUTHZ_UNIFIED §5).
  workerId            Int?                     @map("worker_id")
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamp(6)
  worker              Worker?                  @relation("UserWorker", fields: [workerId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_users_worker")
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  bbSyncLogs          BbSyncLog[]
  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@map("users")
}

/// App-owned role assignment. Supersedes 1.0 `user_roles` (email-based) with userId +
/// scope columns; `managed_sub_department_ids` carries the 1.0 Kadrovska scope.
/// Role values: lowercase catalog in src/common/authz/roles.ts (no DB CHECK by design —
/// BACKEND_RULES §2; assignment endpoint validates via isKnownRole(), guard is default-deny).
model UserRole {
  id                      Int      @id(map: "pk_user_roles") @default(autoincrement()) @map("id")
  userId                  Int      @map("user_id")
  role                    String   @map("role") @db.VarChar(30)
  /// "global" | "project" | "department" | "module"
  scopeType               String   @default("global") @map("scope_type") @db.VarChar(20)
  scopeId                 String?  @map("scope_id") @db.VarChar(64)
  /// 1.0 Kadrovska/prisustvo scope. Semantics: empty/NULL = full scope FOR `menadzment` ONLY
  /// (legacy 1.0 rows); `tim_lider` must have an explicit list (see app_manages_sub_department()).
  managedSubDepartmentIds Int[]    @map("managed_sub_department_ids")
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_roles_user")

  @@unique([userId, role, scopeType, scopeId], map: "uq_user_roles")
  @@index([userId], map: "idx_user_roles_user")
  @@map("user_roles")
}

/// Per-user permission override flags (1.0 pattern: readonly/access/hide flags,
/// `finalni_potpisnik`). deny (allow=false) beats role grants; guard applies AFTER role union.
model UserPermissionOverride {
  id     Int     @id(map: "pk_user_permission_overrides") @default(autoincrement()) @map("id")
  userId Int     @map("user_id")
  /// Permission key (src/common/authz/permissions.ts) or named flag, e.g. "finalni_potpisnik".
  key    String  @map("key") @db.VarChar(64)
  allow  Boolean @map("allow")
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_permission_overrides_user")

  @@unique([userId, key], map: "uq_user_permission_overrides")
  @@map("user_permission_overrides")
}

/// JWT refresh token with rotation support.
///
/// - `tokenHash` is a hash of the opaque refresh token (never store raw tokens).
/// - `revokedAt` marks logout / revocation; `expiresAt` is the natural TTL.
/// - `replacedByTokenId` points to the new token after rotation (self-FK).
model RefreshToken {
  id                Int            @id(map: "pk_refresh_tokens") @default(autoincrement()) @map("id")
  userId            Int            @map("user_id")
  tokenHash         String         @unique(map: "uq_refresh_tokens_token_hash") @map("token_hash") @db.VarChar(255)
  expiresAt         DateTime       @map("expires_at") @db.Timestamp(6)
  revokedAt         DateTime?      @map("revoked_at") @db.Timestamp(6)
  replacedByTokenId Int?           @map("replaced_by_token_id")
  userAgent         String?        @map("user_agent") @db.VarChar(500)
  ipAddress         String?        @map("ip_address") @db.VarChar(45)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_tokens_user")
  replacedBy        RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_refresh_tokens_replaced_by")
  replacedTokens    RefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

/// Append-only audit trail.
///
/// `entityId` is intentionally a `String` so it can hold any natural key shape
/// (numeric ids, codes like `"VISA"`, composite keys serialised as strings).
/// `actorUsername` is a denormalised snapshot so the log survives even if the
/// user row is later deleted (FK uses SetNull).
model AuditLog {
  id            Int      @id(map: "pk_audit_log") @default(autoincrement()) @map("id")
  actorUserId   Int?     @map("actor_user_id")
  actorUsername String?  @map("actor_username") @db.VarChar(255)
  action        String   @map("action") @db.VarChar(100)
  entityType    String?  @map("entity_type") @db.VarChar(100)
  entityId      String?  @map("entity_id") @db.VarChar(100)
  beforeData    Json?    @map("before_data")
  afterData     Json?    @map("after_data")
  metadata      Json?    @map("metadata")
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  actor         User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_audit_log_actor_user")

  @@index([actorUserId], map: "idx_audit_log_actor_user_id")
  @@index([entityType, entityId], map: "idx_audit_log_entity")
  @@index([createdAt], map: "idx_audit_log_created_at")
  @@map("audit_log")
}

// ============================================================================
// BIGBIT SYNC (application-owned; not legacy BigBit tables)
// ----------------------------------------------------------------------------
// Sprint 1 decision: **approach B** — NestJS service connects to SQL Server
// (BigBit) with a read-only client (e.g. `mssql` / tedious), pulls deltas,
// upserts into Postgres via Prisma. `bb_sync_log` = append-only run history;
// `bb_sync_state` = one bookmark row per sync scope (`entity`) with a JSON
// cursor (shape depends on table: lastModifiedAt, lastId, rowversion, …).
// ============================================================================

/// One row per manual/cron/API sync run (BigBit → Postgres).
model BbSyncLog {
  id                    Int           @id(map: "pk_bb_sync_log") @default(autoincrement()) @map("id")
  startedAt             DateTime      @default(now()) @map("started_at") @db.Timestamp(6)
  finishedAt            DateTime?     @map("finished_at") @db.Timestamp(6)
  /// `running` | `success` | `failed` | `partial` — kept as String (no Prisma enum migration churn).
  status                String        @default("running") @map("status") @db.VarChar(20)
  /// `manual` | `cron` | `api`
  trigger               String        @default("manual") @map("trigger") @db.VarChar(20)
  triggeredByUserId     Int?          @map("triggered_by_user_id")
  /// What was synced, e.g. `customers`, `items`, `all_incremental`.
  entityScope           String?       @map("entity_scope") @db.VarChar(100)
  rowsFetched           Int           @default(0) @map("rows_fetched")
  rowsUpserted          Int           @default(0) @map("rows_upserted")
  rowsSkipped           Int           @default(0) @map("rows_skipped")
  errorMessage          String?       @map("error_message")
  metadata              Json?         @map("metadata")
  triggeredBy           User?         @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_bb_sync_log_triggered_by_user")
  syncStatesLastSuccess BbSyncState[] @relation("BbSyncStateLastSuccessLog")

  @@index([entityScope, startedAt], map: "idx_bb_sync_log_entity_scope_started_at")
  @@index([status, startedAt], map: "idx_bb_sync_log_status_started_at")
  @@map("bb_sync_log")
}

// ============================================================================
// IN-APP NOTIFICATIONS (application-owned)
// ----------------------------------------------------------------------------
// D8 first phase (PLAN_dorade_2026-07-10): the "zvonce" — rows are materialised
// PER RECIPIENT worker at emit time (tech-processes control() on rework/scrap,
// handover-drafts submit()) and read/marked by the notifications module.
// NOT the legacy `notifications` model (Was: Info) above — that one is untouched.
// ============================================================================

/// App-owned (2.0, no legacy source). One row per recipient worker; `recipientWorkerId`
/// references `workers.id` WITHOUT a DB FK on purpose — notification history must not
/// block worker maintenance, and reads resolve workers batch-style anyway (relations.ts).
/// Timestamptz like `work_time_entries` (the other 2.0 app-owned production table).
model AppNotification {
  id                Int       @id(map: "pk_app_notifications") @default(autoincrement()) @map("id")
  /// Kind: 'kontrola.skart' | 'kontrola.dorada' | 'primopredaja.nova' — String, not enum (BACKEND_RULES §2).
  type              String    @map("type") @db.VarChar(40)
  /// Fully rendered Serbian UI message (composed at emit time).
  message           String    @map("message") @db.VarChar(500)
  /// Referenced table for UI navigation, e.g. 'work_orders' | 'handover_drafts'.
  refTable          String?   @map("ref_table") @db.VarChar(40)
  refId             Int?      @map("ref_id")
  recipientWorkerId Int       @map("recipient_worker_id")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt            DateTime? @map("read_at") @db.Timestamptz(6)

  @@index([recipientWorkerId, readAt, createdAt(sort: Desc)], map: "idx_app_notifications_recipient_read_created")
  @@map("app_notifications")
}

/// App-owned (2.0, ODLUKE #8 + Miljan t.7). CAM/programiranje status po poziciji
/// (RN): jedan red po `workOrderId`. Pozicija „zahteva CAM" se izvodi iz rutinga
/// (operacija sa `operations.usesPriority=true`) — ovde se pamti SAMO da li je CAM
/// završen + audit ko/kada (JWT worker). `workOrderId` bez DB FK (batch-resolve,
/// isti razlog kao AppNotification). Timestamptz kao ostale 2.0 app-owned tabele.
model CncProgram {
  id                  Int       @id(map: "pk_cnc_programs") @default(autoincrement()) @map("id")
  workOrderId         Int       @map("work_order_id")
  isDone              Boolean   @default(false) @map("is_done")
  /// Radnik (JWT worker_id) koji je čekirao „CAM završen"; NULL kad nije završeno.
  completedByWorkerId Int?      @map("completed_by_worker_id")
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)
  note                String?   @map("note") @db.VarChar(500)
  /// CAM red (prioritizacija prevlačenjem — Miljan/Nikola/Jovica). Rang 1..N nad
  /// rangiranim pozicijama; NULL = nerangirana. Renumeracija bez rupa u servisu.
  queueOrder          Int?      @map("queue_order")
  /// Radnik (svež users.worker_id lookup) koji je poslednji promenio redosled.
  queueSetByWorkerId  Int?      @map("queue_set_by_worker_id")
  queueSetAt          DateTime? @map("queue_set_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workOrderId], map: "uq_cnc_programs_work_order")
  @@map("cnc_programs")
}

/// App-owned (2.0). Izveštaj o neusaglašenosti — digitalizacija Excel evidencija
/// „Škart"/„Dorada" (MODULE_SPEC_kontrola_kvaliteta §4). Broj (NNN/YY) se dodeljuje
/// TEK pri potvrdi (draft: report_number = NULL) → obrisan lažni draft ne pravi rupu
/// u sekvenci. Meki FK-ovi ka work_orders/tech_processes/workers su BEZ DB constrainta
/// (batch-resolve, legacy orphan); jedini pravi FK je nonconformity_workers.report_id.
/// Timestamptz kao ostale 2.0 app-owned tabele (BACKEND_RULES §11.5). NAPOMENA: partial
/// UNIQUE (type, report_number) WHERE report_number IS NOT NULL postoji SAMO u migraciji —
/// Prisma šema ne može izraziti partial unique (WHERE predikat), pa @@unique namerno izostaje.
model NonconformityReport {
  id                  Int                   @id(map: "pk_nonconformity_reports") @default(autoincrement()) @map("id")
  /// 1 = dorada, 2 = škart (poklapa se sa part_quality REWORK/SCRAP).
  type                Int                   @map("type") @db.SmallInt
  /// „028/26" — dodeljuje server pri potvrdi (sekvenca po tip+godina); NULL dok je draft.
  reportNumber        String?               @map("report_number") @db.VarChar(20)
  reportYear          Int                   @map("report_year")
  reportDate          DateTime              @map("report_date") @db.Timestamptz(6)
  /// 0 = draft (auto iz kioska / ručni unos, čeka potvrdu), 1 = potvrđen.
  status              Int                   @default(0) @map("status") @db.SmallInt
  workOrderId         Int?                  @map("work_order_id")
  identNumber         String?               @map("ident_number") @db.VarChar(50)
  sourceTechProcessId Int?                  @map("source_tech_process_id")
  drawingNumber       String?               @map("drawing_number") @db.VarChar(100)
  partName            String?               @map("part_name") @db.VarChar(255)
  customerName        String?               @map("customer_name") @db.VarChar(255)
  quantity            Int                   @map("quantity")
  defectDescription   String                @default("") @map("defect_description")
  cause               String?               @map("cause")
  workUnit            String?               @map("work_unit") @db.VarChar(120)
  culpritText         String?               @map("culprit_text") @db.VarChar(255)
  /// „Odgovoran" — KO/ŠTA je odgovorno za neusaglašenost (odluka vlasnika, jul 2026).
  /// Različito od Izvršioca (radnik na operaciji). Fiksna lista, jedan izbor; String
  /// a ne Prisma enum (BACKEND_RULES §2). Dozvoljene vrednosti:
  /// izvrsilac | kontrolor | masina | materijal | tehnologija | ostalo. NULL = neizjašnjeno.
  responsibleParty    String?               @map("responsible_party") @db.VarChar(50)
  materialCostNote    String?               @map("material_cost_note") @db.VarChar(255)
  coopCostNote        String?               @map("coop_cost_note") @db.VarChar(255)
  spentHoursText      String?               @map("spent_hours_text") @db.VarChar(50)
  spentHours          Decimal?              @map("spent_hours") @db.Decimal(10, 3)
  /// Trošak materijala u kilogramima. AUTO za škart (type=2): quantity × masa jednog
  /// dela (kg). Izvor mase = drawings.weight (PDM XML Weight, po drawing_number +
  /// reviziji RN-a, fallback najviša revizija), fallback work_orders.unprocessed_part_weight
  /// (masa pripremka). Masa ≤ 0 / nepoznata → NULL. Ručna korekcija dozvoljena (PATCH).
  materialKg          Decimal?              @map("material_kg") @db.Decimal(12, 3)
  note                String?               @map("note")
  preventiveMeasures  String?               @map("preventive_measures")
  extra               String?               @map("extra") @db.VarChar(255)
  raisedByWorkerId    Int?                  @map("raised_by_worker_id")
  createdByUserId     Int?                  @map("created_by_user_id")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  culpritWorkers      NonconformityWorker[]
  documents           QualityDocument[]

  @@index([type, status], map: "idx_nonconformity_reports_type_status")
  @@index([reportYear], map: "idx_nonconformity_reports_year")
  @@index([workOrderId], map: "idx_nonconformity_reports_work_order")
  @@map("nonconformity_reports")
}

/// App-owned (2.0). Izvršioci-radnici (M:N) po izveštaju — puni „Moje neusaglašenosti"
/// u Moj profil (K3). `workerId` je meki FK (batch-resolve, kao ostatak sheme); `reportId`
/// je PRAVI FK (obe tabele 2.0 native) sa ON DELETE CASCADE.
model NonconformityWorker {
  id       Int                 @id(map: "pk_nonconformity_workers") @default(autoincrement()) @map("id")
  reportId Int                 @map("report_id")
  workerId Int                 @map("worker_id")
  report   NonconformityReport @relation(fields: [reportId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_nonconformity_workers_report")

  @@unique([reportId, workerId], map: "uq_nonconformity_workers_report_worker")
  @@index([workerId], map: "idx_nonconformity_workers_worker")
  @@map("nonconformity_workers")
}

/// App-owned (2.0). QC dokumenti — skenirani nalozi, kontrolna dokumentacija, foto sa
/// tableta/telefona (MODULE_SPEC_kontrola_kvaliteta §K4-UPLOAD). ODLUKA Nenad 15.07: NEMA
/// share/mount — sadržaj se UPLOADUJE kroz aplikaciju i čuva u `content` (bytea), presedan
/// `drawing_pdfs`. `reportId` je PRAVI FK → nonconformity_reports (ON DELETE SET NULL: brisanje
/// drafta ne briše arhivski dokument). `techProcessId`/`workOrderId`/`identNumber` su MEKI
/// (bez FK — legacy lanac, batch-resolve/pretraga po RN). Dokument SME biti i nevezan (arhivski).
model QualityDocument {
  id               Int                  @id(map: "pk_quality_documents") @default(autoincrement()) @map("id")
  reportId         Int?                 @map("report_id")
  techProcessId    Int?                 @map("tech_process_id")
  workOrderId      Int?                 @map("work_order_id")
  identNumber      String?              @map("ident_number") @db.VarChar(50)
  fileName         String               @map("file_name") @db.VarChar(255)
  contentType      String               @map("content_type") @db.VarChar(100)
  sizeKb           Int                  @map("size_kb")
  content          Bytes                @map("content")
  uploadedByUserId Int?                 @map("uploaded_by_user_id")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  report           NonconformityReport? @relation(fields: [reportId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_quality_documents_report")

  @@index([reportId], map: "idx_quality_documents_report")
  @@index([techProcessId], map: "idx_quality_documents_tech_process")
  @@index([identNumber], map: "idx_quality_documents_ident")
  @@index([createdAt], map: "idx_quality_documents_created")
  @@map("quality_documents")
}

/// Incremental sync cursor per logical scope (`entity` = stable key, e.g. `customers`).
model BbSyncState {
  entity               String     @id(map: "pk_bb_sync_state") @map("entity") @db.VarChar(100)
  /// Opaque cursor — e.g. `{ "lastModifiedAt": "...", "lastId": 123 }` or `{ "lastRowversion": "..." }`.
  cursor               Json?      @map("cursor")
  lastSuccessAt        DateTime?  @map("last_success_at") @db.Timestamp(6)
  lastAttemptAt        DateTime?  @map("last_attempt_at") @db.Timestamp(6)
  lastErrorMessage     String?    @map("last_error_message")
  lastSuccessSyncLogId Int?       @map("last_success_sync_log_id")
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  lastSuccessSyncLog   BbSyncLog? @relation("BbSyncStateLastSuccessLog", fields: [lastSuccessSyncLogId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_bb_sync_state_last_success_log")

  @@map("bb_sync_state")
}

// ============================================================================
// PRAĆENJE PROIZVODNJE — 2.0-native app-owned tabele (F1)
// ----------------------------------------------------------------------------
// Zamena za sy15 (1.0) most: praćenje sedi direktno na 2.0 work_orders / projects /
// tech_processes (BACKEND_RULES §3 — vlasništvo ServoSync-a). Ove tabele drže SAMO
// aplikativni podatak koga NEMA u izvornim tabelama: ručni override-i, napomene,
// operativni plan, aktivacije predmeta i kooperacija. Plan + presuđene odluke O1–O8:
// docs/PLAN_PRACENJE_PROIZVODNJE_2026-07.md §3.2 / §6.
//
// Reference ka work_orders / projects (2.0) i customers (BigBit keš) su MEKI ref-ovi
// (bez DB FK) — kućni obrazac šeme za work_orders (CncProgram / NonconformityReport /
// WorkTimeEntry: „batch-resolve, legacy orphan") i nema presedana hard-FK ka BigBit
// kešu (WorkOrder.externalCustomerId je isto meki). Pravi FK-ovi postoje SAMO među
// ovim novim app-owned tabelama (odeljenja / operativne_aktivnosti / koop_otpremnice).
// Sva vremena Timestamptz(6) (BACKEND_RULES §11.5); statusi String sa /// katalogom
// dozvoljenih vrednosti (BACKEND_RULES §2). createdBy/updatedBy = users.id (Int, meki),
// presedan NonconformityReport.createdByUserId.
// ============================================================================

/// App-owned (2.0, plan §3.2-1). Ručni override praćenja po RN-u (1 red / work_orders.id).
/// Zamena za sy15 `pracenje_manual_overrides` (podaci se migriraju). null `manualStatus` =
/// auto (izvedeno iz kucanja). „Kompletirano" auto-postavlja mašinsku+površinsku i 100% u
/// servisu (docx §4.7). `workOrderId` meki ref → work_orders (bez DB FK).
model PracenjeOverride {
  id              Int      @id(map: "pk_pracenje_overrides") @default(autoincrement()) @map("id")
  workOrderId     Int      @map("work_order_id")
  /// Ručni status; null = auto. Dozvoljeno: 'u_radu' | 'kompletirano' | 'nije_zapoceto'.
  manualStatus    String?  @map("manual_status") @db.VarChar(20)
  /// Ručna mašinska obrada DA/NE; null = auto iz rutinga.
  manualMachining Boolean? @map("manual_machining")
  /// Ručna površinska zaštita DA/NE; null = auto iz rutinga.
  manualSurface   Boolean? @map("manual_surface")
  /// Ručna „fizički urađeno a nije otkucano" količina (komadi); null = bez korekcije (docx §4.6).
  manualQty       Int?     @map("manual_qty")
  reason          String?  @map("reason")
  createdByUserId Int?     @map("created_by_user_id")
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workOrderId], map: "uq_pracenje_overrides_work_order")
  @@map("pracenje_overrides")
}

/// App-owned (2.0, plan §3.2-2). Ručni re-parent pozicije/podsklopa u stablu praćenja
/// (RN → parent RN). `parentWorkOrderId` null = koren (odlepljeno od auto-sastavnice).
/// Zamena za sy15 `pracenje_parent_override`. Meki ref-ovi → work_orders (bez DB FK).
model PracenjeStructureOverride {
  id                Int      @id(map: "pk_pracenje_structure_overrides") @default(autoincrement()) @map("id")
  workOrderId       Int      @map("work_order_id")
  /// Ručno postavljen roditelj (work_orders.id); null = koren / odlepi od auto-hijerarhije.
  parentWorkOrderId Int?     @map("parent_work_order_id")
  createdByUserId   Int?     @map("created_by_user_id")
  updatedByUserId   Int?     @map("updated_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([workOrderId], map: "uq_pracenje_structure_overrides_work_order")
  @@index([parentWorkOrderId], map: "idx_pracenje_structure_overrides_parent")
  @@map("pracenje_structure_overrides")
}

/// App-owned (2.0, plan §3.2-3). Korisnička napomena po predmetu (projectId) i opciono po
/// RN-u (workOrderId; null = napomena na nivou predmeta). Zamena za sy15
/// `pracenje_proizvodnje_napomene`. Meki ref-ovi → projects / work_orders (bez DB FK).
/// NAPOMENA: PG tretira NULL kao različit, pa @@unique(projectId, workOrderId) NE garantuje
/// jedinstvenost napomena na nivou predmeta (workOrderId NULL) — servis to dodatno enforce-uje
/// (isti caveat kao partial-unique kod NonconformityReport-a).
model PracenjeNote {
  id              Int      @id(map: "pk_pracenje_notes") @default(autoincrement()) @map("id")
  projectId       Int      @map("project_id")
  workOrderId     Int?     @map("work_order_id")
  note            String   @map("note")
  createdByUserId Int?     @map("created_by_user_id")
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([projectId, workOrderId], map: "uq_pracenje_notes_project_work_order")
  @@index([projectId], map: "idx_pracenje_notes_project")
  @@map("pracenje_notes")
}

/// App-owned (2.0, plan §3.2-4, odluka O1). Aktivan predmet + redosled liste (↑↓) + ⭐
/// plan-prioritet (top-lista). Spaja sy15 `predmet_aktivacija` / `predmet_prioritet` /
/// `predmet_plan_prioritet`. `projectId` = projects.id (BigBit keš, meki ref bez FK — O1).
/// Istorijski audit ide u 2.0 `audit_log` (append-only).
model PredmetAktivacija {
  id                     Int      @id(map: "pk_predmet_aktivacije") @default(autoincrement()) @map("id")
  projectId              Int      @map("project_id")
  isActive               Boolean  @default(true) @map("is_active")
  /// Drugi checkbox iz Podešavanja predmeta (M7, Nenad 20.07.2026): SAMO za predmete sa
  /// ovim flagom se kreiraju Projektovanje (PB) i Plan montaže praćenja (sy15
  /// `je_projektovanje_montaza`; pb_list_projects = aktivan ∧ ovaj flag).
  isProjektovanjeMontaza Boolean  @default(false) @map("is_projektovanje_montaza")
  /// Redosled u listi aktivnih predmeta (↑↓); null = nerangiran.
  sortPriority           Int?     @map("sort_priority")
  /// ⭐ Slot u „top-listi" plana (max je app-konfiguracija); null = nije na top-listi.
  planPriority           Int?     @map("plan_priority")
  createdByUserId        Int?     @map("created_by_user_id")
  updatedByUserId        Int?     @map("updated_by_user_id")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([projectId], map: "uq_predmet_aktivacije_project")
  @@index([planPriority], map: "idx_predmet_aktivacije_plan_priority")
  @@index([sortPriority], map: "idx_predmet_aktivacije_sort_priority")
  @@map("predmet_aktivacije")
}

/// App-owned (2.0, plan §3.2-6, odluka O3). Šifarnik odeljenja (7 redova iz sy15
/// `core.odeljenje`); nose boju i vođu — semantika drugačija od `work_units` / `workers`.
/// `leadUserId` / `leadWorkerId` meki ref-ovi (users / workers, bez DB FK). Referencira ga
/// `operativne_aktivnosti` pravim FK-om.
model Odeljenje {
  id           Int                   @id(map: "pk_odeljenja") @default(autoincrement()) @map("id")
  code         String                @map("code") @db.VarChar(20)
  name         String                @map("name") @db.VarChar(100)
  /// UI boja reda (hex ili token), npr. „#2E7D32" / „green".
  color        String?               @map("color") @db.VarChar(20)
  sortOrder    Int                   @default(0) @map("sort_order")
  active       Boolean               @default(true) @map("active")
  /// Vođa odeljenja — meki ref → users.id (bez DB FK).
  leadUserId   Int?                  @map("lead_user_id")
  /// Vođa odeljenja — meki ref → workers.id (bez DB FK).
  leadWorkerId Int?                  @map("lead_worker_id")
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  aktivnosti   OperativnaAktivnost[]

  @@unique([code], map: "uq_odeljenja_code")
  @@index([sortOrder], map: "idx_odeljenja_sort_order")
  @@map("odeljenja")
}

/// App-owned (2.0, plan §3.2-5). Operativni plan (Tab2) — aktivnosti po odeljenjima sa
/// zavisnostima i blokadama. Migracija iz sy15 `production.operativna_aktivnost` uz remap
/// RN veza (odluka O4). `odeljenjeId` = pravi FK → odeljenja; ostali ref-ovi (work_orders /
/// projects / zavisi-od / izvor*) su meki (bez DB FK). Polja prate 24-param upsert iz 1.0
/// (dto/pracenje-mutation.dto.ts UpsertAktivnostDto).
model OperativnaAktivnost {
  id                  Int                          @id(map: "pk_operativne_aktivnosti") @default(autoincrement()) @map("id")
  /// sy15 provenance uuid (production.operativna_aktivnost.id) — EXACT idempotency key for the
  /// one-time import (migrate-pracenje-sy15.ts upserts by it). NULL for rows created natively in 2.0.
  legacySy15Id        String?                      @unique(map: "uq_operativne_aktivnosti_legacy_sy15") @map("legacy_sy15_id") @db.Uuid
  workOrderId         Int?                         @map("work_order_id")
  projectId           Int?                         @map("project_id")
  odeljenjeId         Int                          @map("odeljenje_id")
  nazivAktivnosti     String                       @map("naziv_aktivnosti") @db.VarChar(500)
  planiraniPocetak    DateTime?                    @map("planirani_pocetak") @db.Date
  planiraniZavrsetak  DateTime?                    @map("planirani_zavrsetak") @db.Date
  odgovoranUserId     Int?                         @map("odgovoran_user_id")
  odgovoranWorkerId   Int?                         @map("odgovoran_worker_id")
  odgovoranLabel      String?                      @map("odgovoran_label") @db.VarChar(255)
  /// Dozvoljeno: 'nije_krenulo' | 'u_toku' | 'zavrseno' | 'blokirano'.
  status              String                       @default("nije_krenulo") @map("status") @db.VarChar(20)
  /// Dozvoljeno: 'nizak' | 'srednji' | 'visok'.
  prioritet           String                       @default("srednji") @map("prioritet") @db.VarChar(20)
  rb                  Int                          @default(0) @map("rb")
  opis                String?                      @map("opis")
  brojTp              String?                      @map("broj_tp") @db.VarChar(50)
  kolicinaText        String?                      @map("kolicina_text") @db.VarChar(100)
  /// Meki self-ref → operativne_aktivnosti.id (zavisnost); null kad je slobodan tekst.
  zavisiOdAktivnostId Int?                         @map("zavisi_od_aktivnost_id")
  zavisiOdText        String?                      @map("zavisi_od_text") @db.VarChar(500)
  /// Izvor statusa. Dozvoljeno: 'manual' | 'auto_from_pozicija' | 'auto_from_operacije' (sažeto: auto|manual).
  statusMode          String                       @default("manual") @map("status_mode") @db.VarChar(30)
  rizikNapomena       String?                      @map("rizik_napomena")
  /// Poreklo aktivnosti. Dozvoljeno: 'rucno' | 'iz_sastanka' | 'akcioni_plan' | 'iz_tp'.
  /// 'iz_tp' = aktivnost izvedena iz TP-a (nose je uvezene 1.0 aktivnosti); edit ne sme na 400.
  izvor               String                       @default("rucno") @map("izvor") @db.VarChar(30)
  /// Meki ref-ovi na izvorne entitete (akcioni plan / pozicija-RN / TP operacija); bez DB FK.
  izvorAkcioniPlanId  Int?                         @map("izvor_akcioni_plan_id")
  izvorPozicijaId     Int?                         @map("izvor_pozicija_id")
  izvorTpOperacijaId  Int?                         @map("izvor_tp_operacija_id")
  createdByUserId     Int?                         @map("created_by_user_id")
  updatedByUserId     Int?                         @map("updated_by_user_id")
  createdAt           DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  odeljenje           Odeljenje                    @relation(fields: [odeljenjeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_operativne_aktivnosti_odeljenje")
  blokade             OperativnaAktivnostBlokada[]

  @@index([workOrderId], map: "idx_operativne_aktivnosti_work_order")
  @@index([projectId], map: "idx_operativne_aktivnosti_project")
  @@index([odeljenjeId], map: "idx_operativne_aktivnosti_odeljenje")
  @@map("operativne_aktivnosti")
}

/// App-owned (2.0, plan §3.2-5). Append-only istorija blokada aktivnosti (razlog obavezan;
/// ko/kada blokirao/odblokirao). Pravi FK → operativne_aktivnosti (ON DELETE CASCADE).
model OperativnaAktivnostBlokada {
  id                Int                 @id(map: "pk_operativne_aktivnosti_blokade") @default(autoincrement()) @map("id")
  /// sy15 provenance uuid (production.operativna_aktivnost_blok_istorija.id) — EXACT idempotency
  /// key for the block-history import (upsert by it; fixes created_at-NULL duplication). NULL for
  /// blokade created natively in 2.0.
  legacySy15Id      String?             @unique(map: "uq_operativne_aktivnosti_blokade_legacy_sy15") @map("legacy_sy15_id") @db.Uuid
  aktivnostId       Int                 @map("aktivnost_id")
  razlog            String              @map("razlog")
  blockedAt         DateTime            @default(now()) @map("blocked_at") @db.Timestamptz(6)
  blockedByUserId   Int?                @map("blocked_by_user_id")
  unblockedAt       DateTime?           @map("unblocked_at") @db.Timestamptz(6)
  unblockedByUserId Int?                @map("unblocked_by_user_id")
  napomena          String?             @map("napomena")
  aktivnost         OperativnaAktivnost @relation(fields: [aktivnostId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_operativne_aktivnosti_blokade_aktivnost")

  @@index([aktivnostId], map: "idx_operativne_aktivnosti_blokade_aktivnost")
  @@map("operativne_aktivnosti_blokade")
}

/// App-owned (2.0, plan §3.2-7, docx §4.11). Otpremnica ka kooperantu (galvanska / termička /
/// mašinska). `customerId` = customers.id (BigBit keš) — MEKI ref (nema presedana hard-FK ka
/// kešu; WorkOrder.externalCustomerId je isto meki). Auto-„vraćeno" preko međufazne kontrole
/// (odluka O6). Otpremnica se kuca kroz aplikaciju i štampa po obrascu (work-order-print).
model KoopOtpremnica {
  id              Int                    @id(map: "pk_koop_otpremnice") @default(autoincrement()) @map("id")
  customerId      Int                    @map("customer_id")
  /// Vrsta kooperacije. Dozvoljeno: 'galvanska' | 'termicka' | 'masinska'.
  vrsta           String                 @map("vrsta") @db.VarChar(20)
  /// Broj otpremnice (poslovni broj dokumenta).
  broj            String                 @map("broj") @db.VarChar(50)
  datumSlanja     DateTime               @map("datum_slanja") @db.Date
  /// Ukupna kilaža pošiljke (kg); razlomljivo → Decimal.
  kilazaKg        Decimal?               @map("kilaza_kg") @db.Decimal(12, 3)
  napomena        String?                @map("napomena")
  /// Status vraćanja. Dozvoljeno: 'poslato' | 'delimicno_vraceno' | 'vraceno'.
  status          String                 @default("poslato") @map("status") @db.VarChar(20)
  createdByUserId Int?                   @map("created_by_user_id")
  updatedByUserId Int?                   @map("updated_by_user_id")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  stavke          KoopOtpremnicaStavka[]

  @@index([customerId], map: "idx_koop_otpremnice_customer")
  @@index([status], map: "idx_koop_otpremnice_status")
  @@index([datumSlanja], map: "idx_koop_otpremnice_datum_slanja")
  @@map("koop_otpremnice")
}

/// App-owned (2.0, plan §3.2-7). Stavka otpremnice — pozicija (RN) poslata kooperantu. Pravi
/// FK → koop_otpremnice (ON DELETE CASCADE); `workOrderId` meki ref → work_orders (bez DB FK).
/// `returnedAt` / `vracenoKolicina` puni auto-„vraćeno" (O6, prvo kucanje MK posle slanja) ili
/// ručna korekcija; delimična količina = delimično vraćeno.
model KoopOtpremnicaStavka {
  id              Int            @id(map: "pk_koop_otpremnica_stavke") @default(autoincrement()) @map("id")
  otpremnicaId    Int            @map("otpremnica_id")
  workOrderId     Int            @map("work_order_id")
  drawingNumber   String?        @map("drawing_number") @db.VarChar(100)
  nazivPozicije   String?        @map("naziv_pozicije") @db.VarChar(250)
  kolicina        Int            @map("kolicina")
  vracenoKolicina Int            @default(0) @map("vraceno_kolicina")
  tipPresvlake    String?        @map("tip_presvlake") @db.VarChar(100)
  jedinstvenBroj  String?        @map("jedinstven_broj") @db.VarChar(100)
  napomena        String?        @map("napomena")
  returnedAt      DateTime?      @map("returned_at") @db.Timestamptz(6)
  otpremnica      KoopOtpremnica @relation(fields: [otpremnicaId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_koop_otpremnica_stavke_otpremnica")

  @@index([otpremnicaId], map: "idx_koop_otpremnica_stavke_otpremnica")
  @@index([workOrderId], map: "idx_koop_otpremnica_stavke_work_order")
  @@map("koop_otpremnica_stavke")
}

// ============================================================================
// PLAN PROIZVODNJE — 2.0-native app-owned tabele (F5b, plan §4.2, odluke M1/M3/M8)
// ----------------------------------------------------------------------------
// Gašenje sy15 (1.0) mosta za Plan proizvodnje: aplikativni overlay/urgency/koop/skice/
// reassign-audit koje 1.0 drži u `production_*` tabelama sele u glavnu bazu (BACKEND_RULES §3
// vlasništvo). Ovaj korak (F5b-1a) uvodi SAMO app-owned tabele + migracioni skript — read sloj
// (view lanac → native) čeka F5b-0 izviđanje. Plan: docs/PLAN_F5_GASENJE_MOSTA.md §4.
//
// Reference ka work_orders (2.0) i work_order_operations su MEKI ref-ovi (BEZ DB FK) — kućni
// obrazac praćenja (PracenjeOverride/OperativnaAktivnost). `lineId` == work_order_operations.id
// deli ISTI id prostor kao sy15 `line` (dokazano feed-om: op.id AS id) → migracija je COPY bez
// remape. `workOrderId` == work_orders.id (isto meki). Nijedna od 5 tabela nema pravi FK ka
// drugoj. Legacy audit kolone (created_by/updated_by/…) su sy15 tekst (email/uid) i prenose se
// VERBATIM — bez remape na users.id (za razliku od praćenja) da COPY ostane 1:1.
// Timestamptz(6) (BACKEND_RULES §11.5); statusi String sa /// katalogom (BACKEND_RULES §2).
// ============================================================================

/// App-owned (2.0, plan §4.2 (b), F5b). Overlay Plana proizvodnje po operaciji (1 red /
/// work_order + line). Zamena za sy15 `production_overlays` (podaci se migriraju 1:1 COPY-jem —
/// id prostori isti). `workOrderId` = work_orders.id (meki ref); `lineId` = work_order_operations.id
/// (meki ref, ISTI id prostor kao sy15 line). Istorija (production_overlays_history, 112) ide
/// jednokratno u 2.0 `audit_log` (M8), ne u zasebnu tabelu. Bez DB FK.
model PlanProizvodnjeOverlay {
  id                        Int       @id(map: "pk_plan_proizvodnje_overlays") @default(autoincrement()) @map("id")
  /// sy15 provenance (production_overlays.id — bigint autoincrement, NIJE uuid): veza ka history
  /// redovima (overlay_id) i idempotentan re-import. NULL za native 2.0 redove.
  legacySy15Id              BigInt?   @unique(map: "uq_plan_proizvodnje_overlays_legacy_sy15") @map("legacy_sy15_id")
  /// Meki ref → work_orders.id.
  workOrderId               Int       @map("work_order_id")
  /// Meki ref → work_order_operations.id (ISTI id prostor kao sy15 line).
  lineId                    Int       @map("line_id")
  shiftSortOrder            Int?      @map("shift_sort_order")
  /// Lokalni status smene; null = auto (izvedeno iz kucanja). Dozvoljeno: 'waiting' | 'in_progress' | 'blocked'.
  localStatus               String?   @map("local_status") @db.VarChar(20)
  shiftNote                 String?   @map("shift_note")
  assignedMachineCode       String?   @map("assigned_machine_code") @db.VarChar(50)
  camReady                  Boolean   @default(false) @map("cam_ready")
