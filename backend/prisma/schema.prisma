  rfqNumber       String    @map("rfq_number") @db.VarChar(30) // prefiks=predmet-N
  requestId       Int?      @map("request_id") // IDTrebVeza — veza na zahtev (meki ref)
  supplierId      Int       @map("supplier_id") // dobavljač — meki ref (šifarnik komitenata)
  status          String    @default("DRAFT") @map("status") @db.VarChar(20) /// DRAFT | SENT | QUOTED | CLOSED
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6) // BigBit Poslato → timestamp slanja
  emailMessageId  String?   @map("email_message_id") @db.VarChar(128) // Resend message id (audit auto-maila)
  note            String?   @map("note")
  createdByUserId Int?      @map("created_by_user_id")
  updatedByUserId Int?      @map("updated_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
