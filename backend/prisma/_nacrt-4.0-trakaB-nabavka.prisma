// ─────────────────────────────────────────────────────────────────────────────
// NACRT — Traka B (4.0): Nabavka (zahtev → upit dobavljaču → narudžbenica → prijem)
// ─────────────────────────────────────────────────────────────────────────────
// STATUS: PREDLOG za pregled — NIJE u schema.prisma i NIJE migrirano.
// Ne zavisi od GL/konto mapa → SPRINT kandidat (PLAN_TRAKA_B_predmeti-nabavka.md §B).
//
// Konvencije verifikovane iz koda (agent Explore, 19.07):
//   • app-owned tabela: id Int @default(autoincrement()); meki ref = projectId Int (BEZ @relation)
//   • audit: createdByUserId Int? / updatedByUserId Int? (meki ref na users.id, bez @relation)
//   • timestamp NOVE tabele: @db.Timestamptz(6) (Timestamp(6) je samo legacy)
//   • statusi String sa dozvoljenim vrednostima u /// ; količine/novac Decimal (nikad Float)
//   • eksplicitni pk_/fk_/uq_/idx_ nazivi; @map snake_case; @@map snake plural
//   • presedan app-owned: PracenjeNote (schema:2261), PredmetAktivacija (schema:2280)
//
// Merge korak (kad baza + N3 potvrda budu spremni):
//   1) rebaza nakon tuđeg `pracenje` commita   2) prepiši u schema.prisma
//   3) docs/schema-rename-map.md   4) npm run migrate:dev na dev bazi → test → PR
// ─────────────────────────────────────────────────────────────────────────────

/// Was: ZahteviZaNabavku  — zahtev za nabavku (inicira inženjer, CTRL+J/K u BigBit-u).
/// App-owned (2.0, Traka B §B). Meki ref → projects (project_id NOT NULL, kičma), work_orders.
model PurchaseRequest {
  id              Int      @id(map: "pk_purchase_requests") @default(autoincrement()) @map("id")
  requestNumber   String   @map("request_number") @db.VarChar(20)   // NNNN/god (BigBit broj zahteva)
  projectId       Int      @map("project_id")                        // IDPredmetDok — meki ref, NOT NULL (doc 24)
  workOrderId     Int?     @map("work_order_id")                     // IDRadniNalog — meki ref (opciono)
  initiatorUserId Int?     @map("initiator_user_id")                 // inicijator (inženjer) — meki ref users.id
  status          String   @default("DRAFT") @map("status") @db.VarChar(20) /// DRAFT | SUBMITTED | APPROVED | REJECTED | CLOSED
  note            String?  @map("note")
  createdByUserId Int?     @map("created_by_user_id")
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  items           PurchaseRequestItem[]

  @@unique([requestNumber], map: "uq_purchase_requests_number")
  @@index([projectId], map: "idx_purchase_requests_project")
  @@index([status], map: "idx_purchase_requests_status")
  @@map("purchase_requests")
}

/// Was: SpecifikacijaZahtevaNabavke  — stavka zahteva; KreirajUpit flag pokreće upit dobavljaču.
model PurchaseRequestItem {
  id                Int             @id(map: "pk_purchase_request_items") @default(autoincrement()) @map("id")
  requestId         Int             @map("request_id")
  articleId         Int?            @map("article_id")               // meki ref na artikal (šifarnik robe)
  description       String?         @map("description") @db.VarChar(255) // slobodan opis ako artikal nije u šifarniku
  quantity          Decimal         @map("quantity") @db.Decimal(18, 4)  // količina (nikad Float)
  unit              String?         @map("unit") @db.VarChar(10)
  createRfq         Boolean         @default(false) @map("create_rfq") // KreirajUpit — ide li ova stavka u upit
  suggestedSupplierId Int?          @map("suggested_supplier_id")     // predloženi dobavljač — meki ref
  lineNo            Int             @default(0) @map("line_no")

  request           PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade, map: "fk_pr_items_request")

  @@index([requestId], map: "idx_pr_items_request")
  @@map("purchase_request_items")
}

/// Was: T_UpitDobavljacu  — upit (RFQ) poslat dobavljaču; broj = prefiks predmeta + N.
/// Auto-mail preko Faza-0 Resend (PDF prilog); log sentAt umesto BigBit Poslato=True.
model SupplierRfq {
  id              Int      @id(map: "pk_supplier_rfqs") @default(autoincrement()) @map("id")
  rfqNumber       String   @map("rfq_number") @db.VarChar(30)       // prefiks=predmet-N
  requestId       Int?     @map("request_id")                       // IDTrebVeza — veza na zahtev (meki ref)
  supplierId      Int      @map("supplier_id")                       // dobavljač — meki ref (šifarnik komitenata)
  status          String   @default("DRAFT") @map("status") @db.VarChar(20) /// DRAFT | SENT | QUOTED | CLOSED
  sentAt          DateTime? @map("sent_at") @db.Timestamptz(6)       // BigBit Poslato → timestamp slanja
  emailMessageId  String?  @map("email_message_id") @db.VarChar(128) // Resend message id (audit auto-maila)
  note            String?  @map("note")
  createdByUserId Int?     @map("created_by_user_id")
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  items           SupplierRfqItem[]

  @@unique([rfqNumber], map: "uq_supplier_rfqs_number")
  @@index([supplierId], map: "idx_supplier_rfqs_supplier")
  @@index([requestId], map: "idx_supplier_rfqs_request")
  @@map("supplier_rfqs")
}

/// Was: (stavke T_UpitDobavljacu)  — stavka upita; ponuda dobavljača (rok, prihvaćeno).
/// CENA se NE drži ovde — cena tek u narudžbenici (BigBit pravilo, doc 24).
model SupplierRfqItem {
  id                  Int         @id(map: "pk_supplier_rfq_items") @default(autoincrement()) @map("id")
  rfqId               Int         @map("rfq_id")
  requestItemId       Int?        @map("request_item_id")           // veza na stavku zahteva (meki ref)
  articleId           Int?        @map("article_id")
  description         String?     @map("description") @db.VarChar(255)
  quantity            Decimal     @map("quantity") @db.Decimal(18, 4)
  unit                String?     @map("unit") @db.VarChar(10)
  offeredLeadTimeDays Int?        @map("offered_lead_time_days")     // rok isporuke iz ponude
  isAccepted          Boolean     @default(false) @map("is_accepted") // PrihvacenaPonuda
  lineNo              Int         @default(0) @map("line_no")

  rfq                 SupplierRfq @relation(fields: [rfqId], references: [id], onDelete: Cascade, map: "fk_rfq_items_rfq")

  @@index([rfqId], map: "idx_rfq_items_rfq")
  @@map("supplier_rfq_items")
}

/// Was: T_Trebovanja  — narudžbenica dobavljaču (nastaje iz prihvaćene ponude).
/// Cena se drži OVDE (stavke). Status-mašina: DRAFT→ORDERED→SIGNED→LOCKED→CLOSED.
model PurchaseOrder {
  id              Int      @id(map: "pk_purchase_orders") @default(autoincrement()) @map("id")
  orderNumber     String   @map("order_number") @db.VarChar(20)
  rfqId           Int?     @map("rfq_id")                            // IDUpita — veza na upit (meki ref)
  supplierId      Int      @map("supplier_id")
  projectId       Int?     @map("project_id")                       // meki ref (nasledi iz zahteva)
  status          String   @default("DRAFT") @map("status") @db.VarChar(20) /// DRAFT | ORDERED | SIGNED | LOCKED | RECEIVED | CLOSED
  orderedAt       DateTime? @map("ordered_at") @db.Timestamptz(6)    // Poruceno
  currency        String   @default("RSD") @map("currency") @db.VarChar(3)
  note            String?  @map("note")
  createdByUserId Int?     @map("created_by_user_id")
  updatedByUserId Int?     @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  items           PurchaseOrderItem[]

  @@unique([orderNumber], map: "uq_purchase_orders_number")
  @@index([supplierId], map: "idx_purchase_orders_supplier")
  @@index([rfqId], map: "idx_purchase_orders_rfq")
  @@index([status], map: "idx_purchase_orders_status")
  @@map("purchase_orders")
}

/// Was: (stavke T_Trebovanja)  — stavka narudžbenice; naručeno vs primljeno (3-way match).
/// receivedQuantity default = orderedQuantity pri prijemu (BigBit IsporucenaKolicina).
model PurchaseOrderItem {
  id                Int           @id(map: "pk_purchase_order_items") @default(autoincrement()) @map("id")
  orderId           Int           @map("order_id")
  rfqItemId         Int?          @map("rfq_item_id")                // IDStavkeUpita (meki ref)
  requestItemId     Int?          @map("request_item_id")            // IDZahtevaZaNabavku (meki ref)
  articleId         Int?          @map("article_id")
  description       String?       @map("description") @db.VarChar(255)
  orderedQuantity   Decimal       @map("ordered_quantity") @db.Decimal(18, 4)  // TrebKol
  receivedQuantity  Decimal       @default(0) @map("received_quantity") @db.Decimal(18, 4) // IsporucenaKolicina
  unitPrice         Decimal?      @map("unit_price") @db.Decimal(18, 4)         // cena (tek ovde, ne u upitu)
  unit              String?       @map("unit") @db.VarChar(10)
  lineNo            Int           @default(0) @map("line_no")

  order             PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade, map: "fk_po_items_order")

  @@index([orderId], map: "idx_po_items_order")
  @@map("purchase_order_items")
}

