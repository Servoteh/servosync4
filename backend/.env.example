# Kopiraj u .env: cp .env.example .env
# Postgres iz docker-compose.yml mora da radi: docker compose up -d db

DATABASE_URL="postgresql://servosync:servosync_dev@localhost:5435/servosync?schema=public"
PORT=3000

# Optional: serve the built frontend (Next static export `out/`) from THIS API on the
# same origin — LAN/offline access without Cloudflare or CORS (front na http://<host>:3000,
# API na .../api). Point at the dir that holds index.html/login.html. Prazno = samo API
# (dev/default). Na serveru je to montirani volume, npr. /app/frontend-static
# (v. docs/infra/INFRASTRUKTURA.md → „Front na :3000").
FRONTEND_STATIC_DIR=

# --- BigBit / QBigTehn (MSSQL) source for on-demand sync ---
# Read-only login (bridge_reader already exists in QBigTehn). Reachable over the
# company WireGuard VPN. Use the FQDN (or IP 192.168.64.25) — the bare NetBIOS
# name "Vasa-SQL" does not resolve on macOS.
BIGBIT_DB_HOST=Vasa-SQL.servoteh.local
BIGBIT_DB_PORT=5765
BIGBIT_DB_NAME=QBigTehn
BIGBIT_DB_USER=bridge_reader
BIGBIT_DB_PASSWORD=
BIGBIT_DB_ENCRYPT=false
BIGBIT_DB_TRUST_SERVER_CERT=true
BIGBIT_DB_REQUEST_TIMEOUT_MS=30000
BIGBIT_DB_POOL_MAX=5

# --- Auth (JWT) ---
JWT_SECRET=change_me_in_production
# Access token TTL. Kratko (24h) jer refresh token tiho obnavlja sesiju (§7).
JWT_EXPIRES_IN=24h
# Refresh token životni vek u danima (KLIZNO: svaka rotacija = novih N dana).
# POST /api/auth/refresh rotira par; reuse opozvanog tokena opoziva sve tokene korisnika.
# Default 30. Prod: 30.
REFRESH_TOKEN_TTL_DAYS=30
# SSO sa ServoSync 1.0/1.5 shell-a (iframe modul „Tehnologija"): JWT_SECRET
# sy15 GoTrue stacka (na serveru: ~/servosync15/.env). POST /api/auth/sso
# verifikuje 1.0 access token ovim secretom i po email-u (users.email) izda
# naš token. Prazno = SSO isključen (endpoint vraća 401).
SY15_JWT_SECRET=
# sy15 (1.0) PostgreSQL baza — drugi datasource za 3.0 pilot module (Reversi;
# MODULE_SPEC_reversi.md §0). Na serveru: sy15-db kontejner (ista mašina).
# Prazno = pilot moduli vraćaju 503, ostatak aplikacije radi normalno.
SY15_DATABASE_URL=
# sy15 PostgREST baza URL za SSO JIT provisioning (čitanje 1.0 role RPC-om
# get_my_user_roles sa korisnikovim tokenom). Prazno = javni
# https://api.servosync.servoteh.com/rest/v1; na serveru bolje LAN vhost
# http://192.168.64.28:8090/rest/v1 (radi i bez interneta/CF).
SY15_REST_URL=

# --- Authz (RBAC guard rollout, AUTHZ_UNIFIED.md §6.1/§8) ---
# false (default) = SHADOW MODE: guard evaluates + logs would-be 403s, but allows.
# true = enforce (403 on missing permission). Rollback = flip back + restart.
AUTHZ_ENFORCE=false

# Tvrda brava na vidljivost/izmenu zarada (kadrovska.salary) — zarezom razdvojeni
# mejlovi koji JEDINI smeju plate, NEZAVISNO od role/override (odluka vlasnika 21.07).
# Prazno/nepostavljeno = default (Nenad + Nevena). Podesivo bez deploya (restart).
KADROVSKA_SALARY_ALLOWLIST=nenad.jarakovic@servoteh.com,nevena.knezevic@servoteh.com

# --- Legacy primopredaje guard (tranziciona politika do cutover-a) ---
# Derivacioni sync izvodi drawing_handovers redove iz tRN atributa (legacy_rn_id !=
# NULL) i pri svakom prolazu ih PREGAZI iz QBigTehn-a (legacy = izvor istine do
# cutover-a). true (default) = approve/reject/launch/prepare/return nad deriviranim
# redovima vraća 409 — odobravanje se radi u QBigTehn-u (Miljan). Nativni redovi
# (legacy_rn_id = NULL) nisu blokirani. UKIDANJE NA CUTOVER: false + compose up
# (isti rollback obrazac kao AUTHZ_ENFORCE); kolona legacy_rn_id ostaje kao provenance.
HANDOVER_LEGACY_GUARD=true

# --- Transakcioni mejl (Resend; src/common/mail/mail.service.ts) ---
# API ključ Resend naloga (isti servis i verifikovan domen kao ServoSync 1.0).
# Prazno = DRY-RUN: mejl se loguje ali se NE šalje — aplikacija radi normalno.
RESEND_API_KEY=
# „From" adresa (verifikovan domen). Prazno = "Servoteh <obavestenja@servoteh.com>".
RESEND_FROM=

# --- Štampa nalepnica (RAW TSPL2 → TCP; POST /tech-processes/labels/print) ---
# Mrežni termalni štampač (TSC ML340P). Server šalje direktno na TCP 9100.
LABEL_PRINTER_HOST=192.168.70.20
LABEL_PRINTER_PORT=9100

# --- PRIVREMENO: test radnici (ODLUKE #32) ---
# CSV worker id-jeva koji preskaču SERVISNE kiosk provere (machine-access, kontrolor-auth,
# razdvajanje dužnosti) — za testiranje tokova. UKINUTI brisanjem reda + compose up -d.
AUTHZ_TEST_WORKER_IDS=

# --- Read-only (test) nalozi ---
# CSV user id-jeva (users.id) kojima je SVAKA mutacija (POST/PUT/PATCH/DELETE) blokirana
# sa 403 + porukom "test nalog"; GET radi normalno, /auth/login i /auth/sso nisu pogođeni.
# Front dobija readOnly=true u login/sso/me odgovoru i prikazuje trajni baner.
# Prod: 49 = test@servoteh.com. Rollback = obriši red + compose up -d.
AUTHZ_READONLY_USER_IDS=

# sy15 storage-api (bucket reversal-pdf, sastanci-arhiva, sastanak-slike… — 8 modula).
# ⚠️ MORA biti JAVNI gateway URL sa /storage/v1 prefiksom, npr.
#   SY15_STORAGE_URL=https://api.servosync.servoteh.com/storage/v1
# NE interni docker host (sy15-storage:5000): (a) `/storage/v1` prefiks skida Caddy
# gateway — storage-api (Fastify) ga ne poznaje pa direktan pogodak vraća 404; (b)
# signUrl() vraća `${base}${signedURL}` koji otvara BROWSER, pa base mora biti javno
# dostupan. Interni host je 20.07.2026 oborio SVE BE storage tokove (upload+sign) —
# vidi docs/PLAN_SASTANCI_PRIMEDBE_2026-07-20.md §S0. + service key sy15 stacka
# (~/servosync15/.env SERVICE_ROLE). Prazno = PDF/storage rute vraćaju 503.
SY15_STORAGE_URL=
SY15_SERVICE_KEY=
# --- Talas D / D1: dvostrano upravljanje nalozima (Podešavanja WRITE) ---
# GoTrue admin baza sy15 stacka (create/reset). Prazno = izvedeno iz SY15_REST_URL
# (`/rest/v1`→`/auth/v1`). SY15_SERVICE_KEY (gore) je apikey/Bearer. Prazno oboje = 503.
SY15_AUTH_URL=
# Link u welcome/reset mejlu (kadr_notification_log outbox); default servosync.servoteh.com.
SY15_APP_URL=

# --- Zahtevi (AI PM modul) — AI cevovod (MODULE_SPEC_zahtevi §4/§13.3) ---
# Modeli za AI trijažu/analizu idu kroz AiProviderService (ANTHROPIC_API_KEY / OPENAI_API_KEY).
# Bez ključa: analiza pada u FAILED not_configured, ali modul radi normalno (doktrina §10.4).
# Promena modela = samo restart (bez deploya). Presuda §13.3: Haiku trijaža / Sonnet analiza.
# Trijaža — jeftin/brz model (auto na svaki submit): ocena 0–5 + klasifikacija + duplikati.
ZAHTEVI_TRIAGE_MODEL=claude-haiku-4-5-20251001
# Detaljna analiza — jak model (SAMO na admin klik „Odobri AI analizu"): AC/rizici/Claude paket.
ZAHTEVI_ANALYSIS_MODEL=claude-sonnet-5
# Obaveštenja podnosiocu mejlom (MODULE_SPEC §9, presuda §13.4): default TRUE (uključeno odmah).
# Šalje se na odluku (approve/reject/needs-info) i na završetak (DONE). Ide kroz MailService
# (Resend); bez RESEND_API_KEY je DRY-RUN (loguje, ne šalje). Slanje NIKAD ne obara radnju.
# Isključi samo eksplicitno: ZAHTEVI_MAIL_NOTIFY=false.
ZAHTEVI_MAIL_NOTIFY=true
# Na svaki submit ide i mejl administratorima o novoj ideji / dopunjenom zahtevu.
# PRESUDA 24.07: ako je ZAHTEVI_ADMIN_MAILS postavljen (CSV), to je AUTORITATIVNA "to" lista
# (override, NE fallback) — bira ko prima ove mejlove (neki admini, npr. Luka/Nevena, ne žele).
# ZAHTEVI_ADMIN_CC (CSV, opciono) ide kao CC. Ako je ZAHTEVI_ADMIN_MAILS prazan → svi aktivni
# admini iz baze (users.role='admin').
ZAHTEVI_ADMIN_MAILS=
ZAHTEVI_ADMIN_CC=

# Neusaglašenosti na montaži (zahtev 004/26, MODULE_SPEC_montaza_neusaglasenosti §2):
# na svaku novu prijavu ide mejl rolи `menadzment` (aktivni korisnici sa email-om), a na
# ZAVRSENO mejl podnosiocu. Ide kroz MailService (Resend); bez RESEND_API_KEY je DRY-RUN.
# Slanje NIKAD ne obara prijavu. Isključi samo eksplicitno: MONTAZA_NM_MAIL_NOTIFY=false.
MONTAZA_NM_MAIL_NOTIFY=true

# Auto-predlog mesečnog grida iz kapije (zahtev 012/26, presuda Nenad 24.07): sistem
# svakodnevno upiše PREDLOG sati iz STVARNOG prisustva (kucanje → v_attendance_vs_grid)
# za prazne grid-dane SVIH odeljenja; INSERT ... ON CONFLICT DO NOTHING (nikad ne gazi
# ručni unos), marker work_hours.last_edited_by='auto:kapija'. Okidač = INTERNI tik
# (setInterval ~30min; obrada „juče" posle 05:00 Europe/Belgrade; SAMO kad je
# NODE_ENV=production — dev/CI ne piše u živu bazu). Ručni backfill/dry-run =
# POST /kadrovska/grid/autofill-run (gornja granica se klampuje na juče). Kill-switch:
# postavi na false da se i tik i svaki upis (dnevni I backfill) pretvore u no-op.
# Default UKLJUČENO.
KADROVSKA_GRID_AUTOFILL=true
