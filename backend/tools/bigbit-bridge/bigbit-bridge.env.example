# BigBit bridge config (runs on ubuntusrv). Copy to bigbit-bridge.env and fill in.
#   cp bigbit-bridge.env.example bigbit-bridge.env
# bigbit-bridge.env is git-ignored.

# --- BigBit source .mdb (local path on the ubuntu server) --------------------
# Reader is mdb-tools (ignores Access ULS) so NO password/PID/workgroup needed.
# May be a single FILE or a DROP FOLDER: if it points to a folder, the newest
# *.mdb inside is used (BigBit drops the export into a Samba share on THIS server
# - see README "Deljeni drop folder"). Recommended = the shared drop folder:
BB_SRC_MDB=/srv/bigbit-incoming
# (single-file example: /home/admnenad/bb-analiza/BB_T_26_11-07-26.mdb)

# --- PostgreSQL (local docker container on the SAME host) --------------------
# We write via `docker exec`, so PG 5432 does NOT need to be exposed on the LAN
# and there is NO dedicated bb_sync role.
BB_PG_CONTAINER=servosync-pg
BB_PG_USER=servosync
BB_PG_DB=servosync

# --- runtime ----------------------------------------------------------------
BB_MDBTOOLS_IMAGE=servosync/mdbtools:local
BB_TMP_DIR=/tmp/bigbit-bridge
BB_LOG_FILE=/home/admnenad/bigbit-bridge/bigbit-bridge.log

# BB_ONLY=R_Grupa      # sync a single table (Access name or pg target), for pilot/debug
# BB_DRY_RUN=1         # ROLLBACK instead of COMMIT (full run, nothing persists)
